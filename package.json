    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.12.0",
    "nodemailer": "^7.0.13",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "schema-dts": "^2.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
