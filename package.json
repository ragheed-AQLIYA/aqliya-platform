{
  "name": "aqliya-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:localcontent-pilot": "powershell -ExecutionPolicy Bypass -File scripts/localcontent/run-localcontent-pilot.ps1",
    "dev:safe": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --webpack",
    "build": "prisma generate && next build --webpack",
    "build:safe": "node --max-old-space-size=6144 ./node_modules/next/dist/bin/next build --webpack",
    "postinstall": "prisma generate && node scripts/platform/validate-env.mjs",
    "prepare": "husky || true",
    "validate:env": "node scripts/platform/validate-env.mjs",
    "analyze": "node scripts/platform/bundle-analyzer.js",
    "backup": "node scripts/platform/backup.mjs",
    "start": "next start",
    "start:standalone": "node scripts/platform/start-standalone.mjs",
    "start:standalone:e2e": "node scripts/platform/start-standalone.mjs --e2e",
    "staging:probe": "node scripts/platform/staging-probe.mjs",
    "parallel:local-bundle": "npm run demo:smoke && npm test && npm run build",
    "smoke:local": "node scripts/platform/post-deploy-smoke.mjs --base-url http://localhost:3000",
    "auth:smoke-local": "node scripts/platform/test-auth-csrf-login.mjs",
    "lint": "eslint src/",
    "test": "jest --ci --passWithNoTests --forceExit",
    "test:unit": "jest --testPathPatterns='src/__tests__/unit/'",
    "test:integration": "jest --testPathPatterns='src/__tests__/integration/' --runInBand",
    "test:i18n": "jest src/__tests__/i18n/ --no-coverage",
    "test:integration:setup": "docker compose -f docker-compose.test.yml up -d && npx prisma db push",
    "seed:audit": "tsx prisma/seed-audit.ts",
    "tb:preview": "tsx -r ./scripts/mock-server-only.cjs scripts/audit/tb-classification-preview.ts",
    "tb:upload": "tsx -r ./scripts/mock-server-only.cjs scripts/audit/tb-upload-demo.ts",
    "lc:matrix:import": "tsx scripts/localcontent/import-lc-verification-matrix.ts",
    "lc:signals": "tsx -r ./scripts/mock-server-only.cjs scripts/localcontent/lc-signals-from-engagement.ts",
    "lc:link-audit": "tsx scripts/localcontent/link-lc-project-audit.ts",
    "audit:health": "tsx scripts/platform/audit-health-check.ts",
    "audit:action-guards": "node scripts/platform/audit-action-guards.mjs",
    "db:verify-pgvector": "tsx scripts/platform/verify-pgvector-staging.ts",
    "db:pgvector-health": "node scripts/platform/check-pgvector-health.mjs",
    "local-ai:smoke": "tsx -r ./scripts/mock-server-only.cjs scripts/ic/local-ai-phase0-smoke.ts",
    "tb:benchmark": "tsx -r ./scripts/mock-server-only.cjs scripts/audit/tb-classification-benchmark.ts",
    "ic:smoke:cycle5": "tsx scripts/ic/ic-cycle5-smoke.ts",
    "ic:smoke:cycle5:live": "tsx scripts/ic/ic-cycle5-smoke.ts --live",
    "cycle6:smoke:audit-ai": "tsx -r ./scripts/mock-server-only.cjs scripts/ic/cycle6-governed-audit-smoke.ts",
    "factory:smoke": "tsx -r ./scripts/mock-server-only.cjs scripts/audit/factory-pilot-smoke.ts",
    "factory:smoke:static": "node scripts/audit/factory-pilot-smoke-static.mjs",
    "shalfa:setup": "node -r ./scripts/mock-server-only.cjs --import tsx scripts/audit/shalfa-pilot-setup.mjs",
    "shalfa:validate": "node -r ./scripts/mock-server-only.cjs --import tsx scripts/audit/shalfa-live-validation.mjs",
    "shalfa:tb-classify": "tsx -r ./scripts/mock-server-only.cjs scripts/audit/shalfa-real-tb-classification.ts",
    "phase-3b:mine": "node -r ./scripts/mock-server-only.cjs --import tsx scripts/audit/phase-3b-erp-intelligence-mining.mjs",
    "phase-3b:rebenchmark": "tsx -r ./scripts/mock-server-only.cjs scripts/audit/shalfa-real-tb-classification.ts -- --rules-only",
    "phase-3b1:holdout": "tsx -r ./scripts/mock-server-only.cjs scripts/audit/phase-3b1-holdout-validation.ts",
    "phase-3b2:stratified": "tsx -r ./scripts/mock-server-only.cjs scripts/audit/phase-3b2-stratified-holdout.ts",
    "phase-3c:backfill": "node -r ./scripts/mock-server-only.cjs --import tsx scripts/audit/phase-3c-backfill-firm-memory.mjs",
    "phase-3c:validate": "tsx -r ./scripts/mock-server-only.cjs scripts/audit/phase-3c-memory-validation.ts",
    "phase-3d:validate-governance": "tsx -r ./scripts/mock-server-only.cjs scripts/audit/phase-3d-validate-governance.ts",
    "tb:memory-reuse-rate": "node -r ./scripts/mock-server-only.cjs --import tsx scripts/audit/tb-memory-reuse-rate.mjs",
    "tb:memory-baseline": "tsx -r ./scripts/mock-server-only.cjs scripts/audit/tb-memory-baseline-report.ts",
    "cycle6:full-run": "powershell -ExecutionPolicy Bypass -File scripts/ic/cycle6-full-run.ps1",
    "cycle6:remote-smoke": "powershell -ExecutionPolicy Bypass -File scripts/ic/cycle6-remote-smoke.ps1",
    "test:ic01:pgvector": "tsx scripts/ic/run-ic01-pgvector-test.ts",
    "demo:smoke": "node scripts/platform/demo-smoke-check.mjs",
    "eval:skills": "tsx -r ./scripts/mock-server-only.cjs scripts/ic/evaluate-skills.ts --mock",
    "eval:skills:mock": "tsx -r ./scripts/mock-server-only.cjs scripts/ic/evaluate-skills.ts --mock",
    "eval:skills:live": "tsx -r ./scripts/mock-server-only.cjs scripts/ic/evaluate-skills.ts --live",
    "eval:skill": "tsx -r ./scripts/mock-server-only.cjs scripts/ic/evaluate-skills.ts --mock --skill",
    "db:verify-mfa": "tsx scripts/platform/verify-mfa-db.ts",
    "db:backup": "tsx scripts/platform/db-backup.ts",
    "db:restore": "tsx scripts/platform/db-restore.ts",
    "pilot:daily": "tsx scripts/platform/pilot-daily-monitor.ts",
    "rtl:audit": "tsx scripts/platform/rtl-audit.ts",
    "backup:verify": "tsx scripts/platform/backup-verify.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:local": "cypress run --config baseUrl=http://localhost:3000",
    "cy:local:prep": "echo Run: npm run start:standalone:e2e (terminal 1) then npm run cy:local (terminal 2)",
    "test:e2e": "npm run build && npx next start & npx wait-on http://localhost:3000 && cypress run",
    "platform:backfill-orgs:dry": "tsx scripts/platform/backfill-platform-organizations.ts",
    "platform:backfill-orgs:apply": "tsx scripts/platform/backfill-platform-organizations.ts --apply",
    "platform:verify-org-links": "tsx scripts/platform/verify-platform-organization-links.ts",
    "platform:backfill-workspaces:dry": "tsx scripts/platform/backfill-client-workspaces.ts",
    "platform:backfill-workspaces:apply": "tsx scripts/platform/backfill-client-workspaces.ts --apply",
    "platform:verify-workspace-links": "tsx scripts/platform/verify-client-workspace-links.ts",
    "platform:audit-log:dry": "tsx scripts/platform/verify-platform-audit-log-write.ts",
    "platform:audit-log:apply": "tsx scripts/platform/verify-platform-audit-log-write.ts --apply",
    "platform:verify-audit-logs": "tsx scripts/platform/verify-platform-audit-logs.ts",
    "platform:auditos-dual-write:dry": "tsx scripts/platform/verify-auditos-dual-write.ts",
    "platform:auditos-dual-write:apply": "tsx scripts/platform/verify-auditos-dual-write.ts --apply",
    "platform:decisionos-dual-write:dry": "tsx scripts/platform/verify-decisionos-dual-write.ts",
    "platform:decisionos-dual-write:apply": "tsx scripts/platform/verify-decisionos-dual-write.ts --apply",
    "office-ai:service:dry": "tsx scripts/platform/verify-office-ai-task-service.ts",
    "office-ai:service:apply": "tsx scripts/platform/verify-office-ai-task-service.ts --apply",
    "office-ai:validate-files:dry": "tsx scripts/platform/verify-office-ai-file-validation.ts",
    "office-ai:validate-files:apply": "tsx scripts/platform/verify-office-ai-file-validation.ts --apply",
    "office-ai:extraction:dry": "tsx scripts/platform/verify-office-ai-extraction.ts",
    "office-ai:extraction:apply": "tsx scripts/platform/verify-office-ai-extraction.ts --apply",
    "office-ai:seed": "tsx scripts/platform/seed-office-ai.ts",
    "office-ai:seed:dry": "tsx scripts/platform/seed-office-ai.ts --dry",
    "office-ai:v01:dry": "tsx scripts/platform/verify-office-ai-v01.ts",
    "office-ai:v01:apply": "tsx scripts/platform/verify-office-ai-v01.ts --apply",
    "start:network": "next start -H 0.0.0.0 -p 3000"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1064.0",
