{
  "name": "aqliya-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:safe": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --webpack",
    "build": "prisma generate && next build --webpack",
    "build:safe": "node --max-old-space-size=6144 ./node_modules/next/dist/bin/next build --webpack",
    "postinstall": "prisma generate && node scripts/validate-env.mjs",
    "prepare": "husky || true",
    "validate:env": "node scripts/validate-env.mjs",
    "analyze": "node scripts/bundle-analyzer.js",
    "backup": "node scripts/backup.mjs",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:unit": "jest --testPathPatterns='src/__tests__/unit/'",
    "test:integration": "jest --testPathPatterns='src/__tests__/integration/' --runInBand",
    "test:i18n": "jest src/__tests__/i18n/ --no-coverage",
    "test:integration:setup": "docker compose -f docker-compose.test.yml up -d && npx prisma db push",
    "seed:audit": "tsx prisma/seed-audit.ts",
    "audit:health": "tsx scripts/audit-health-check.ts",
    "db:backup": "tsx scripts/db-backup.ts",
    "db:restore": "tsx scripts/db-restore.ts",
    "pilot:daily": "tsx scripts/pilot-daily-monitor.ts",
    "rtl:audit": "tsx scripts/rtl-audit.ts",
    "backup:verify": "tsx scripts/backup-verify.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:e2e": "npm run build && npx next start & npx wait-on http://localhost:3000 && cypress run",
    "platform:backfill-orgs:dry": "tsx scripts/backfill-platform-organizations.ts",
    "platform:backfill-orgs:apply": "tsx scripts/backfill-platform-organizations.ts --apply",
    "platform:verify-org-links": "tsx scripts/verify-platform-organization-links.ts",
    "platform:backfill-workspaces:dry": "tsx scripts/backfill-client-workspaces.ts",
    "platform:backfill-workspaces:apply": "tsx scripts/backfill-client-workspaces.ts --apply",
    "platform:verify-workspace-links": "tsx scripts/verify-client-workspace-links.ts",
    "platform:audit-log:dry": "tsx scripts/verify-platform-audit-log-write.ts",
    "platform:audit-log:apply": "tsx scripts/verify-platform-audit-log-write.ts --apply",
    "platform:verify-audit-logs": "tsx scripts/verify-platform-audit-logs.ts",
    "platform:auditos-dual-write:dry": "tsx scripts/verify-auditos-dual-write.ts",
    "platform:auditos-dual-write:apply": "tsx scripts/verify-auditos-dual-write.ts --apply",
    "platform:decisionos-dual-write:dry": "tsx scripts/verify-decisionos-dual-write.ts",
    "platform:decisionos-dual-write:apply": "tsx scripts/verify-decisionos-dual-write.ts --apply",
    "office-ai:service:dry": "tsx scripts/verify-office-ai-task-service.ts",
    "office-ai:service:apply": "tsx scripts/verify-office-ai-task-service.ts --apply",
    "office-ai:validate-files:dry": "tsx scripts/verify-office-ai-file-validation.ts",
    "office-ai:validate-files:apply": "tsx scripts/verify-office-ai-file-validation.ts --apply",
    "office-ai:extraction:dry": "tsx scripts/verify-office-ai-extraction.ts",
    "office-ai:extraction:apply": "tsx scripts/verify-office-ai-extraction.ts --apply",
    "office-ai:seed": "tsx scripts/seed-office-ai.ts",
    "office-ai:seed:dry": "tsx scripts/seed-office-ai.ts --dry",
    "office-ai:v01:dry": "tsx scripts/verify-office-ai-v01.ts",
    "office-ai:v01:apply": "tsx scripts/verify-office-ai-v01.ts --apply",
    "start:network": "next start -H 0.0.0.0 -p 3000"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.4.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.53.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookies-next": "^6.1.1",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.12.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "schema-dts": "^2.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.39",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cypress": "^15.15.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "shadcn": "^4.6.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npx eslint --fix",
      "npx prettier --write"
    ],
    "*.{json,css,md}": [
      "npx prettier --write"
    ]
  }
}
