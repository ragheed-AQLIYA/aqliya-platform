generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

enum DecisionStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum DecisionType {
  TENDER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ScenarioType {
  BEST_CASE
  EXPECTED_CASE
  WORST_CASE
}

enum RecommendationType {
  GO
  GO_WITH_CONDITIONS
  NO_GO
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuditAction {
  DECISION_CREATED
  DECISION_UPDATED
  RECOMMENDATION_UPDATED
  PATTERN_EXTRACTED
  ALERT_RESOLVED
  SECTOR_ASSIGNED
  BENCHMARK_CREATED
  OUTPUT_PUBLISHED
  OUTPUT_UNPUBLISHED
}

model Organization {
  id               String                   @id @default(cuid())
  name             String
  users            User[]
  decisions        Decision[]
  auditLogs        AuditLog[]
  signals          DecisionMonitoringSignal[]
  alerts           DecisionRiskAlert[]
  decisionPatterns DecisionPattern[]
  reports          DecisionReport[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

model User {
  id                  String       @id @default(cuid())
  email               String       @unique
  name                String
  passwordHash         String?
  role                UserRole     @default(OPERATOR)
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  ownedDecisions      Decision[]   @relation("DecisionOwner")
  reviewedDecisions   Decision[]   @relation("DecisionReviewer")
  approvedDecisions   Decision[]   @relation("DecisionApprover")
  approvals           Approval[]   @relation("ApprovalApprover")
  auditLogs           AuditLog[]
  publishedRecommendations Recommendation[] @relation("RecommendationPublisher")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model Decision {
  id             String        @id @default(cuid())
  title          String
  type           DecisionType  @default(TENDER)
  ownerId        String
  owner          User          @relation("DecisionOwner", fields: [ownerId], references: [id])
  reviewerId     String?
  reviewer       User?         @relation("DecisionReviewer", fields: [reviewerId], references: [id])
  approverId     String?
  approver       User?         @relation("DecisionApprover", fields: [approverId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  status         DecisionStatus @default(DRAFT)
  tenderProfile  TenderProfile?
  objectives     Objective[]
  constraints    Constraint[]
  assumptions    Assumption[]
  alternatives   Alternative[]
  risks          Risk[]
  framework      DecisionFramework?
  decisionScenarios DecisionScenario[]
  riskAnalyses   DecisionRiskAnalysis[]
  scenarios      Scenario[]
  simulations    SimulationResult[]
  recommendation Recommendation?
  approvals      Approval[]
  auditLogs      AuditLog[]
  reports        DecisionReport[]
  signals        DecisionMonitoringSignal[]
  alerts         DecisionRiskAlert[]
  // A-3: Sector assignment
  sectorId       String?
  sector         Sector?        @relation(fields: [sectorId], references: [id])
  decisionPatterns DecisionPattern?
  sectorPatterns SectorPattern[] // Added opposite relation for SectorPattern
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model DecisionFramework {
  id              String   @id @default(cuid())
  decisionId      String   @unique
  decision        Decision @relation(fields: [decisionId], references: [id])
  context         String
  purpose         String
  options         String
  criteria        String
  values          String
  informationGaps String
  certainty       String
  assumptions     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DecisionScenario {
  id                   String   @id @default(cuid())
  decisionId           String
  decision             Decision @relation(fields: [decisionId], references: [id])
  riskAnalysis         DecisionRiskAnalysis?
  name                 String
  description          String
  assumptions          String
  expectedOutcome      String
  affectedStakeholders String
  requiredConditions   String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model DecisionRiskAnalysis {
  id                   String           @id @default(cuid())
  decisionId           String
  decision             Decision         @relation(fields: [decisionId], references: [id])
  scenarioId           String           @unique
  scenario             DecisionScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  risks                String
  tradeoffs            String
  sacrifices           String
  opportunityCosts     String
  stakeholderRisks     String
  operationalRisks     String
  strategicRisks       String
  knowledgeRisks       String
  uncertaintyLevel     String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model Objective {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id])
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Constraint {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id])
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Assumption {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id])
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Alternative {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id])
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Risk {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id])
  description String
  level       RiskLevel
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TenderProfile {
  id                     String   @id @default(cuid())
  decisionId             String   @unique
  decision               Decision @relation(fields: [decisionId], references: [id])
  clientName             String
  estimatedContractValue Float
  estimatedCost          Float
  durationMonths         Int
  requiredCapacity       Int
  internalAvailableCapacity Int
  strategicFitScore      Int
  riskLevel              RiskLevel
  marginEstimate         Float
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Scenario {
  id          String       @id @default(cuid())
  decisionId  String
  decision    Decision     @relation(fields: [decisionId], references: [id])
  type        ScenarioType
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  simulation  SimulationResult?

  @@unique([decisionId, type])
}

model SimulationResult {
  id                  String       @id @default(cuid())
  decisionId          String
  decision            Decision     @relation(fields: [decisionId], references: [id])
  scenarioId         String?       @unique
  scenario            Scenario?    @relation(fields: [scenarioId], references: [id])
  feasibilityScore    Float
  financialScore      Float
  capacityScore       Float
  riskScore           Float
  strategicFitScore   Float
  overallDecisionScore Float
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model DecisionMonitoringSignal {
  id            String   @id @default(cuid())
  decisionId    String
  decision      Decision @relation(fields: [decisionId], references: [id])
  organizationId String
  organization  Organization @relation(fields: [organizationId], references: [id])
  // Required: source of signal
  source        String   // "assumption" | "risk" | "scenario" | "execution"
  // Required: link to A-1 entity
  referenceId   String   // ID of the assumption/risk/scenario that triggered this
  signalType    String   // e.g., "risk-increased", "assumption-invalidated"
  description   String
  severity      SignalSeverity @default(INFO)
  status        SignalStatus @default(NEW)
  // No manual creation - system only
  generatedBy  String   @default("system") //Always "system"
  acknowledgedBy String?
  acknowledgedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  // Opposite relation for alerts triggered by this signal
  alerts        DecisionRiskAlert[]

  @@index([organizationId])
}

model DecisionRiskAlert {
  id              String   @id @default(cuid())
  decisionId      String
  decision        Decision @relation(fields: [decisionId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  // Required: what triggered this alert
  triggeringSignalId String   @unique
  triggeringSignal  DecisionMonitoringSignal @relation(fields: [triggeringSignalId], references: [id])
  alertType       String   // e.g., "scenario-risk-emerged", "assumption-invalidated"
  description     String
  severity        AlertSeverity @default(MEDIUM)
  status          AlertStatus @default(OPEN)
  // Must always require human review
  requiresReview Boolean  @default(true)
  // Never auto-resolve
  reviewedBy     String?
  reviewedAt     DateTime?
  resolution     String?  // Only set after human review
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
}

enum SignalSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
}

enum SignalStatus {
  NEW
  ACKNOWLEDGED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED  // Only after human review, never auto
}

model Recommendation {
  id                  String   @id @default(cuid())
  decisionId          String   @unique
  decision            Decision @relation(fields: [decisionId], references: [id])
  recommendedAction    String
  rationale           String
  expectedNextState   String
  scopeExclusions     String
  assumptionsUsed     String
  risksAccepted       String
  risksRejected       String
  humanReviewRequired Boolean @default(true)
  isClientVisible     Boolean  @default(false)
  publishedAt         DateTime?
  publishedById       String?
  publishedBy         User?    @relation("RecommendationPublisher", fields: [publishedById], references: [id])
  publishedVersion    Int      @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Approval {
  id          String        @id @default(cuid())
  decisionId  String
  decision    Decision      @relation(fields: [decisionId], references: [id])
  approverId  String
  approver    User          @relation("ApprovalApprover", fields: [approverId], references: [id])
  status      ApprovalStatus @default(PENDING)
  comments    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id])
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      AuditAction
  entity      String?
  before      String?
  after       String?
  createdAt   DateTime @default(now())

  @@index([organizationId])
}

// ==================== A-3 Intelligence Layer ====================

model Sector {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  code        String   @unique
  isActive    Boolean  @default(true)

  // Relations
  benchmarks  SectorBenchmark[]
  patterns    SectorPattern[]
  playbooks   SectorPlaybook[]
  rules       SectorRule[]
  decisions   Decision[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SectorBenchmark {
  id          String   @id @default(cuid())
  sectorId    String
  sector      Sector   @relation(fields: [sectorId], references: [id])

  metricName  String
  value       Float
  unit        String
  benchmarkType String

  // Per A-3 design: not static
  sourceType  String   @default("manual") // "manual" | "derived" | "assumption"
  confidence  Float    @default(1.0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sectorId, metricName, benchmarkType])
}

model SectorPattern {
  id             String   @id @default(cuid())
  sectorId       String
  sector         Sector   @relation(fields: [sectorId], references: [id])

  patternType    String
  patternKey     String

  // Incremental fields
  occurrenceCount  Int      @default(1)
  lastObservedAt  DateTime  @default(now())
  confidenceScore Float

  sourceDecisionId String?
  sourceDecision   Decision? @relation(fields: [sourceDecisionId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sectorId, patternType, patternKey])
}

model DecisionPattern {
  id            String   @id @default(cuid())
  decisionId    String   @unique
  decision      Decision @relation(fields: [decisionId], references: [id])
  organizationId String
  organization  Organization @relation(fields: [organizationId], references: [id])

  patternScope  String   @default("DECISION") // "DECISION" | "SECTOR" | "CROSS_SECTOR"

  extractedAt   DateTime @default(now())
  confidence    Float

  // No raw analysis stored in DB

  @@index([organizationId])
}

model SectorPlaybook {
  id          String   @id @default(cuid())
  sectorId    String
  sector      Sector   @relation(fields: [sectorId], references: [id])

  title       String
  content     String
  playbookType String
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SectorRule {
  id          String   @id @default(cuid())
  sectorId    String
  sector      Sector   @relation(fields: [sectorId], references: [id])

  ruleName    String
  condition   String
  action      String
  isActive    Boolean  @default(false)
  requiresHumanReview Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DecisionReport {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id])
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id])
  title       String
  content     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId])
}

// ==================== AuditOS Models ====================

model AuditOrganization {
  id                  String                @id @default(cuid())
  name                String
  slug                String                @unique
  jurisdiction        String
  regulatoryFramework String
  governanceRules     Json?
  status              String                @default("active")
  clients             AuditClient[]
  users               AuditUser[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  deletedAt           DateTime?
}

model AuditUser {
  id               String          @id @default(cuid())
  organizationId   String
  organization     AuditOrganization @relation(fields: [organizationId], references: [id])
  email            String
  name             String
  role             String          @default("operator")
  status           String          @default("active")
  lastLoginAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId, status])
}

model AuditClient {
  id                  String          @id @default(cuid())
  organizationId      String
  organization        AuditOrganization @relation(fields: [organizationId], references: [id])
  name                String
  registrationNumber  String?
  industry            String
  reportingFramework  String          @default("ifrs_for_smes")
  fiscalPeriodEnd     String          @default("12-31")
  currencyCode        String          @default("SAR")
  status              String          @default("active")
  contactEmail        String?
  contactPhone        String?
  engagements         AuditEngagement[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  @@index([organizationId, status])
}

model AuditEngagement {
  id               String            @id @default(cuid())
  organizationId   String
  clientId         String
  client           AuditClient       @relation(fields: [clientId], references: [id])
  fiscalPeriod     String
  engagementType   String            @default("full_audit")
  status           String            @default("draft")
  team             Json?
  alerts           Json?
  governanceRules  Json?
  accountMappings  AuditAccountMapping[]
  trialBalances    AuditTrialBalance[]
  evidences        AuditEvidence[]
  findings         AuditFinding[]
  recommendations  AuditRecommendation[]
  reviewComments   AuditReviewComment[]
  approvalRecords  AuditApprovalRecord[]
  publications     AuditPublicationPackage[]
  events           AuditEvent[]
  aiOutputs        AuditAiOutput[]
  pilotFeedback    PilotFeedback[]
  pilotBlockers    ProductionBlocker[]
  pilotSignoffs    PilotSignoff[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model AuditTrialBalance {
  id             String                 @id @default(cuid())
  engagementId   String
  engagement     AuditEngagement       @relation(fields: [engagementId], references: [id])
  importTimestamp DateTime              @default(now())
  sourceFile     String
  fileHash       String?
  trustState     String                @default("pending")
  totalDebits    Float                 @default(0)
  totalCredits   Float                 @default(0)
  variance       Float                 @default(0)
  lines          AuditTrialBalanceLine[]
  createdAt      DateTime              @default(now())
}

model AuditTrialBalanceLine {
  id              String            @id @default(cuid())
  trialBalanceId  String
  trialBalance    AuditTrialBalance @relation(fields: [trialBalanceId], references: [id])
  accountCode     String
  accountName     String
  debitAmount     Float             @default(0)
  creditAmount    Float             @default(0)
  balance         Float             @default(0)
  accountType     String?
  currency        String            @default("SAR")
}

model AuditCanonicalAccount {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  category          String
  subcategory       String?
  statementType     String
  reportingFramework String  @default("ifrs_for_smes")
  version           String   @default("1.0")
  displayOrder      Int                @default(0)
  mappings          AuditAccountMapping[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model AuditAccountMapping {
  id                    String               @id @default(cuid())
  engagementId          String
  engagement            AuditEngagement      @relation(fields: [engagementId], references: [id])
  sourceAccountId       String
  sourceAccountCode     String
  sourceAccountName     String
  debitAmount           Float                @default(0)
  creditAmount          Float                @default(0)
  canonicalAccountId    String?
  canonicalAccount      AuditCanonicalAccount? @relation(fields: [canonicalAccountId], references: [id])
  confidence            Float?
  mappingType           String               @default("ai_suggested")
  status                String               @default("pending")
  statementClassification String?
  mappedBy              String?
  mappedAt              DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
}

model AuditFinancialStatement {
  id             String        @id @default(cuid())
  engagementId   String
  statementType  String
  title          String
  status         String        @default("draft")
  lines          Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model AuditDisclosureNote {
  id                String   @id @default(cuid())
  engagementId      String
  noteNumber        String
  title             String
  noteType          String
  content           String
  linkedStatementLine String?
  missingInformation Json?
  aiDrafted         Boolean  @default(false)
  status            String   @default("draft")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AuditEvidence {
  id           String             @id @default(cuid())
  engagementId String
  engagement   AuditEngagement   @relation(fields: [engagementId], references: [id])
  filename     String
  fileType     String
  fileSize     Int                @default(0)
  fileHash     String?
  storageKey   String?
  uploadedBy   String?
  uploadedAt   DateTime?
  state        String             @default("missing")
  links        AuditEvidenceLink[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model AuditEvidenceLink {
  id         String       @id @default(cuid())
  evidenceId String
  evidence   AuditEvidence @relation(fields: [evidenceId], references: [id])
  targetType String
  targetId   String
  linkType   String       @default("supports")
  context    String?
  createdBy  String?
  createdAt  DateTime     @default(now())
}

model AuditFinding {
  id               String            @id @default(cuid())
  engagementId     String
  engagement       AuditEngagement   @relation(fields: [engagementId], references: [id])
  title            String
  findingType      String            @default("observation")
  severity         String            @default("medium")
  materiality      String            @default("immaterial")
  description      String
  rootCause        String?
  impact           String?
  status           String            @default("draft")
  relatedAccountIds Json?
  relatedEvidenceIds Json?
  aiSuggested      Boolean           @default(false)
  assignedTo       String?
  recommendations  AuditRecommendation[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model AuditRecommendation {
  id               String          @id @default(cuid())
  engagementId     String
  engagement       AuditEngagement @relation(fields: [engagementId], references: [id])
  findingId        String
  finding          AuditFinding    @relation(fields: [findingId], references: [id])
  title            String
  description      String
  recommendedAction String
  impactAssessment String?
  riskLevel        String          @default("medium")
  status           String          @default("suggested")
  aiContributed    Boolean         @default(false)
  aiSuggestionId   String?
  reviewerDecision String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model AuditReviewComment {
  id              String          @id @default(cuid())
  engagementId    String
  engagement      AuditEngagement @relation(fields: [engagementId], references: [id])
  targetType      String
  targetId        String
  reviewerId      String
  reviewerName    String
  comment         String
  requiredAction  String          @default("none")
  resolution      String?
  status          String          @default("open")
  createdAt       DateTime        @default(now())
  resolvedAt      DateTime?
}

model AuditApprovalRecord {
  id            String          @id @default(cuid())
  engagementId  String
  engagement    AuditEngagement @relation(fields: [engagementId], references: [id])
  approverId    String
  approverName  String
  approverRole  String
  action        String
  rationale     String?
  targetType    String
  targetId      String
  createdAt     DateTime        @default(now())
}

model AuditPublicationPackage {
  id            String          @id @default(cuid())
  engagementId  String
  engagement    AuditEngagement @relation(fields: [engagementId], references: [id])
  status        String          @default("draft")
  publishedAt   DateTime?
  publishedBy   String?
  lockedAt      DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model AuditEvent {
  id             String          @id @default(cuid())
  engagementId   String
  engagement     AuditEngagement @relation(fields: [engagementId], references: [id])
  eventType      String
  actorId        String
  actorName      String
  actorRole      String
  targetType     String
  targetId       String
  previousState  String          @default("")
  newState       String          @default("")
  description    String
  aiRelated      Boolean         @default(false)
  metadata       Json?
  timestamp      DateTime        @default(now())
  createdAt      DateTime        @default(now())

  @@index([engagementId, eventType, timestamp])
}

model AuditAiOutput {
  id               String          @id @default(cuid())
  engagementId     String
  engagement       AuditEngagement @relation(fields: [engagementId], references: [id])
  suggestionType   String
  inputContext     String?
  outputContent    String
  confidence       Float?
  modelVersion     String?
  status           String   @default("suggested")
  acceptedBy       String?
  acceptedAt       DateTime?
  rejectedBy       String?
  rejectedAt       DateTime?
  sourceEntityType String?
  sourceEntityId   String?
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([engagementId, sourceEntityType, sourceEntityId])
}

model PilotFeedback {
  id             String          @id @default(cuid())
  engagementId   String
  engagement     AuditEngagement @relation(fields: [engagementId], references: [id])
  title          String
  description    String
  source         String
  category       String
  severity       String          @default("medium")
  status         String          @default("open")
  decision       String?
  owner          String?
  nextAction     String?
  createdBy      String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ProductionBlocker {
  id              String          @id @default(cuid())
  engagementId    String?
  engagement      AuditEngagement? @relation(fields: [engagementId], references: [id])
  title           String
  description     String
  category        String
  severity        String          @default("critical")
  status          String          @default("open")
  requiredBefore  String          @default("production")
  owner           String?
  resolutionPlan  String?
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model PilotSignoff {
  id              String          @id @default(cuid())
  engagementId    String
  engagement      AuditEngagement @relation(fields: [engagementId], references: [id])
  checklistItem   String
  status          String          @default("pending")
  signedBy        String?
  signedAt        DateTime?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([engagementId, checklistItem])
}
