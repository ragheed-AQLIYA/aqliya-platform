}

// ─── WorkflowOS ─────────────────────────────────────────────────────────

model WorkflowTemplate {
  id                     String        @id @default(cuid())
  organizationId         String
  platformOrganizationId String?
  name                   String
  description            String?
  category               String        @default("general") // general | approval | review | inspection | custom
  status                 String        @default("active")
  steps                  Json          @default("[]") // Array of workflow step definitions
  metadata               Json?
  createdById            String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  records WorkflowRecord[]

  @@index([organizationId, category, createdAt])
  @@index([platformOrganizationId, createdAt])
  @@index([status])
}

model WorkflowRecord {
  id                     String           @id @default(cuid())
  organizationId         String
  platformOrganizationId String?
  templateId             String
  template               WorkflowTemplate @relation(fields: [templateId], references: [id])
  title                  String
  description            String?
  status                 String           @default("pending") // pending | in_progress | completed | rejected | cancelled
  currentStep            Int              @default(0)
  steps                  Json             @default("[]") // Snapshot of steps at creation time
  stepResults            Json             @default("{}") // Results per step
  assignedToId           String?
  priority               String           @default("medium") // low | medium | high | urgent
  dueDate                DateTime?
  completedAt            DateTime?
  metadata               Json?
  createdById            String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  // Export approval fields (L5)
  exportStatus           String           @default("none") // none | requested | approved | rejected
  exportRequestedAt      DateTime?
  exportRequestedById    String?
  exportApprovedAt       DateTime?
  exportApprovedById     String?
  exportRejectedReason   String?

  // Escalation fields (L5)
  escalatedAt            DateTime?
  escalatedToId          String?

  @@index([organizationId, status, createdAt])
  @@index([organizationId, templateId, createdAt])
  @@index([platformOrganizationId, createdAt])
  @@index([assignedToId, status])
  @@index([dueDate])
}

// ─── LocalContactOS ─────────────────────────────────────────────────────

model LocalContact {
  id                     String             @id @default(cuid())
  organizationId         String
  platformOrganizationId String?
