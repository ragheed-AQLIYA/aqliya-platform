  reviewedBy     User?    @relation("BatchReviewer", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  approvedById   String?
  approvedBy     User?    @relation("BatchApprover", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  metadata       Json?
  createdById    String?
  createdAt      DateTime @default(now())

  @@index([connectionId, status, createdAt])
  @@index([organizationId, status])
}

// ==================== RBAC — Roles & Permissions ====================

model Permission {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  group       String
  description String?

  rolePermissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
}

model Role {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  type        String   @default("SYSTEM")
  description String?

  permissions RolePermission[]
  assignments UserRoleAssignment[]
  sodRulesA   SeparationOfDutyRule[] @relation("SoDRuleRoleA")
  sodRulesB   SeparationOfDutyRule[] @relation("SoDRuleRoleB")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model UserRoleAssignment {
  id             String   @id @default(cuid())
  userId         String
  roleId         String
  organizationId String
  grantedById    String?
  reason         String?
  isActive       Boolean  @default(true)
  revokedAt      DateTime?
  revokedById    String?
  role           Role     @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, organizationId, isActive])
  @@index([roleId])
  @@index([grantedById])
}

// ==================== Separation of Duties ====================

model SeparationOfDutyRule {
  id             String   @id @default(cuid())
  organizationId String
  description    String?
  roleAId        String
  roleBId        String
  conflictLevel  ConflictLevel @default(HARD)
  isActive       Boolean  @default(true)
  createdById    String?

  // Relations
  roleA     Role         @relation("SoDRuleRoleA", fields: [roleAId], references: [id])
  roleB     Role         @relation("SoDRuleRoleB", fields: [roleBId], references: [id])
  conflicts SoDConflict[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([isActive])
  @@index([roleAId])
  @@index([roleBId])
}

model SoDConflict {
  id             String   @id @default(cuid())
  ruleId         String
  userId         String
  organizationId String
  roleAId        String?
  roleBId        String?
  description    String?
  detectedAt     DateTime @default(now())
  resolvedAt     DateTime?
  resolution     String?
  resolvedById   String?

  // Relations
  rule SeparationOfDutyRule @relation(fields: [ruleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, organizationId])
  @@index([ruleId])
  @@index([resolvedAt])
}

// ==================== Vault / Secrets Management ====================

model VaultEntry {
  id                String   @id @default(cuid())
  key               String
  displayName       String?
  encryptedValue    String
  keyIdentifier     String
  description       String?
  category          String   @default("general")
  environment       String?
  status            String   @default("ACTIVE")
  version           Int      @default(1)
  lastRotatedAt     DateTime?
  lastAccessedAt    DateTime?
  accessCount       Int      @default(0)
  rotationPeriodDays Int     @default(90)
  expiresAt         DateTime?
  metadata          Json?
  previousVersionId String?
  createdById       String?
  organizationId    String?
  deletedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key, organizationId])
  @@index([organizationId, category])
  @@index([deletedAt])
}

// ==================== Encryption Key Management ====================

model EncryptionKey {
  id          String   @id @default(cuid())
  keyId       String   @unique
  algorithm   String
  keyHash     String
  status      String   @default("active")
  description String?
  createdBy   String?
  retiredAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ==================== Download Ticket Gate ====================

model DownloadTicket {
