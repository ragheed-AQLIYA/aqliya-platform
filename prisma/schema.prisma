model AuditValidationRun {
  id             String                 @id @default(cuid())
  engagementId   String
  engagement     AuditEngagement        @relation(fields: [engagementId], references: [id])
  validationType String
  status     String                 @default("completed") // completed | failed | running
  trustState     String                 @default("conditional")
  summary        String?
  issueCount     Int                    @default(0)
  criticalCount  Int                    @default(0)
  highCount      Int                    @default(0)
  mediumCount    Int                    @default(0)
  lowCount       Int                    @default(0)
  createdBy      String
  createdAt      DateTime               @default(now())
  completedAt    DateTime?
  issues         AuditValidationIssue[]

  @@index([engagementId])
  @@index([status])
  @@index([createdAt])
}

model AuditValidationIssue {
  id              String                       @id @default(cuid())
  validationRunId String
  validationRun   AuditValidationRun           @relation(fields: [validationRunId], references: [id])
  engagementId    String
  engagement      AuditEngagement              @relation(fields: [engagementId], references: [id])
  checkType       String
  severity        String
  status          String    @default("open")
  title           String
  description     String
  message         String
  accountCode     String?
  accountName     String?
  expectedValue   Float?
  actualValue     Float?
  difference      Float?
  createdAt       DateTime                     @default(now())
  dispositions    AuditValidationDisposition[]

  @@index([validationRunId])
  @@index([engagementId])
  @@index([severity])
  @@index([status])
}

model AuditValidationDisposition {
  id           String               @id @default(cuid())
  issueId      String
  issue        AuditValidationIssue @relation(fields: [issueId], references: [id])
  engagementId String
  engagement   AuditEngagement      @relation(fields: [engagementId], references: [id])
  action       String
  rationale    String?
  disposedBy   String
  disposedAt   DateTime             @default(now())

  @@index([issueId])
  @@index([engagementId])
}

// ==================== Sunbul Models ====================

enum SunbulUserRole {
  PlatformAdmin
  Operator
  Reviewer
}

enum SunbulMembershipStatus {
  Active
  Suspended
}

enum SunbulRecordStatus {
  Draft
  UnderReview
  Approved
  Archived
}

enum SunbulReviewStatus {
  Pending
  Approved
  Returned
}

enum SunbulAuditAction {
  CLIENT_CREATED
  CLIENT_UPDATED
  MEMBERSHIP_CREATED
  MEMBERSHIP_ROLE_CHANGED
  MEMBERSHIP_STATUS_CHANGED
  RECORD_CREATED
  RECORD_UPDATED
  RECORD_SUBMITTED
  RECORD_APPROVED
  RECORD_RETURNED
  RECORD_ARCHIVED
  RECORD_EXPORTED
  REVIEW_CREATED
  DOCUMENT_CREATED
  DOCUMENT_DELETED
}

model SunbulClient {
  id                     String   @id @default(cuid())
  name                   String
  slug                   String   @unique
  status                 String   @default("active")
  config                 Json?
  platformOrganizationId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  platformOrganization PlatformOrganization? @relation(fields: [platformOrganizationId], references: [id])
  memberships          SunbulUserMembership[]
  records              SunbulRecord[]
  documents            SunbulDocument[]
  reviews              SunbulReview[]
  auditEvents          SunbulAuditEvent[]

  @@index([status])
  @@index([createdAt])
  @@index([platformOrganizationId])
}

model SunbulUserMembership {
  id        String                 @id @default(cuid())
  clientId  String
  client    SunbulClient           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String
  role      SunbulUserRole         @default(Operator)
  status    SunbulMembershipStatus @default(Active)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@unique([clientId, userId])
  @@index([clientId])
  @@index([userId])
  @@index([role])
}

model SunbulRecord {
  id          String             @id @default(cuid())
  clientId    String
  client      SunbulClient       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        String             @default("CASE")
  status      SunbulRecordStatus @default(Draft)
  priority    String             @default("medium")
  createdById String
  submittedAt DateTime?
  approvedAt  DateTime?
  archivedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  documents SunbulDocument[]
  reviews   SunbulReview[]

  @@index([clientId])
  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

model SunbulDocument {
  id           String       @id @default(cuid())
  clientId     String
  client       SunbulClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recordId     String
  record       SunbulRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  fileName     String
  fileType     String
  fileSize     Int          @default(0)
  storageKey   String
  uploadedById String
  createdAt    DateTime     @default(now())

  @@index([clientId])
  @@index([recordId])
  @@index([uploadedById])
}

model SunbulReview {
  id         String             @id @default(cuid())
  clientId   String
  client     SunbulClient       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recordId   String
  record     SunbulRecord       @relation(fields: [recordId], references: [id], onDelete: Cascade)
  reviewerId String
  status     SunbulReviewStatus @default(Pending)
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([clientId])
  @@index([recordId])
  @@index([reviewerId])
}

model SunbulAuditEvent {
  id         String            @id @default(cuid())
  clientId   String
  client     SunbulClient      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recordId   String?
  actorId    String
  action     SunbulAuditAction
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime          @default(now())

  @@index([clientId])
  @@index([recordId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// ==================== LocalContentOS (Strategic Second Product) ====================

model LocalContentProject {
  id                     String   @id @default(cuid())
  organizationId         String
  platformOrganizationId String?
  clientWorkspaceId      String?
  projectId              String?
  name                   String
  reportingPeriod        String
  scopeDescription       String?
  status                 String   @default("Draft") // Draft, DataCollection, ClassificationInProgress, EvidenceReview, FindingsDrafted, InReview, Returned, Approved, Rejected, ReportReady, Exported, Archived
  localContentScore      Float?
  createdById            String?
  createdByName          String?
  metadata               Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  suppliers       LocalContentSupplier[]
  spendRecords    LocalContentSpendRecord[]
  classifications LocalContentClassification[]
  evidence        LocalContentEvidence[]
  findings        LocalContentFinding[]
  reviews         LocalContentReview[]
  approvals       LocalContentApproval[]
  reports         LocalContentReport[]
  auditEvents     LocalContentAuditEvent[]

  @@index([organizationId, createdAt])
  @@index([platformOrganizationId, createdAt])
  @@index([clientWorkspaceId, createdAt])
  @@index([projectId, createdAt])
  @@index([status])
  @@index([createdAt])
}

model LocalContentSupplier {
  id                     String              @id @default(cuid())
  projectId              String
  project                LocalContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                   String
  crNumber               String?
  localityClassification String? // local, non_local, mixed, unclassified
  localContentPercentage Float?
  ownershipType          String? // Saudi, foreign, joint_venture
  workforceLocalPct      Float?
  status                 String              @default("active") // active, inactive, under_review
  metadata               Json?
  createdById            String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  spendRecords    LocalContentSpendRecord[]
  classifications LocalContentClassification[]
  evidenceItems   LocalContentEvidence[]

  @@index([projectId, status])
  @@index([status])
  @@index([createdAt])
}

model LocalContentSpendRecord {
  id                String               @id @default(cuid())
  projectId         String
  project           LocalContentProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplierId        String
  supplier          LocalContentSupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  amount            Float
  currency          String               @default("SAR")
  category          String // goods, services, construction, technology, logistics, other
  contractReference String?
  period            String
  description       String?
  metadata          Json?
  createdById       String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  classifications       LocalContentClassification[]
  localContentEvidences LocalContentEvidence[]

  @@index([projectId, createdAt])
  @@index([supplierId, createdAt])
  @@index([category])
  @@index([createdAt])
}

model LocalContentClassification {
  id                  String                   @id @default(cuid())
  projectId           String
  project             LocalContentProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplierId          String?
  supplier            LocalContentSupplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  spendRecordId       String?
  spendRecord         LocalContentSpendRecord? @relation(fields: [spendRecordId], references: [id], onDelete: SetNull)
  classifiedBy        String?
  localPercentage     Float
  classificationBasis String // certificate, self_declaration, contract_term, analyst_estimate
  confidence          String                   @default("unverified") // high, medium, low, unverified
  notes               String?
  reviewStatus        String                   @default("draft") // draft, reviewed, confirmed, disputed
  metadata            Json?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([projectId, createdAt])
  @@index([supplierId, createdAt])
  @@index([spendRecordId, createdAt])
  @@index([reviewStatus])
  @@index([createdAt])
}

model LocalContentEvidence {
  id            String                   @id @default(cuid())
  projectId     String
  project       LocalContentProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplierId    String?
  supplier      LocalContentSupplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  spendRecordId String?
  spendRecord   LocalContentSpendRecord? @relation(fields: [spendRecordId], references: [id], onDelete: SetNull)
  findingId     String?
  finding       LocalContentFinding?     @relation(fields: [findingId], references: [id], onDelete: SetNull)
  filename      String
  fileType      String // pdf, xlsx, docx, jpg, png, csv, txt
  mimeType      String?
  storageKey    String?
  fileHash      String?
  sizeBytes     Int?
  evidenceType  String // certificate, contract, attestation, invoice, registration, other
  status        String                   @default("uploaded") // uploaded, linked, reviewed, verified, rejected, missing
  reviewedById  String?
  reviewedAt    DateTime?
  metadata      Json?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([projectId, status, createdAt])
  @@index([supplierId, createdAt])
  @@index([spendRecordId, createdAt])
  @@index([findingId, createdAt])
  @@index([fileHash])
  @@index([createdAt])
}

model LocalContentFinding {
  id                  String              @id @default(cuid())
  projectId           String
  project             LocalContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type                String // evidence_gap, low_content, unclassified_supplier, data_quality, compliance_risk
  severity            String              @default("medium") // low, medium, high, critical
  title               String
  description         String
  linkedSupplierId    String?
  linkedSpendRecordId String?
  status              String              @default("draft") // draft, submitted, reviewed, resolved, dismissed
  createdById         String?
  createdByName       String?
  metadata            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  evidenceItems LocalContentEvidence[]

  @@index([projectId, severity, status])
  @@index([type, createdAt])
  @@index([status])
  @@index([createdAt])
}

model LocalContentReview {
  id           String              @id @default(cuid())
  projectId    String
  project      LocalContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewerId   String
  reviewerName String
  action       String // submitted, returned, commented
  comments     String?
  status       String              @default("pending") // pending, in_review, returned, completed
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([projectId, createdAt])
  @@index([reviewerId, createdAt])
  @@index([status])
  @@index([createdAt])
}

model LocalContentApproval {
  id               String              @id @default(cuid())
  projectId        String
  project          LocalContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approverId       String
  approverName     String
  decision         String // approved, rejected
  comments         String?
  approvalSnapshot Json?
  createdAt        DateTime            @default(now())

  @@index([projectId, createdAt])
  @@index([approverId, createdAt])
  @@index([decision])
  @@index([createdAt])
}

model LocalContentReport {
  id              String              @id @default(cuid())
  projectId       String
  project         LocalContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportType      String // assessment_summary, supplier_register, spend_classification, gap_risk, evidence_index, final_package
  format          String // pdf, xlsx
  status          String              @default("generated") // generated, downloaded, archived
  generatedById   String?
  generatedByName String?
  storageKey      String?
  disclaimer      String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([projectId, createdAt])
  @@index([reportType, createdAt])
  @@index([status])
  @@index([createdAt])
}

model LocalContentAuditEvent {
  id         String              @id @default(cuid())
  projectId  String
  project    LocalContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorId    String
  actorName  String?
  action     String
  entityType String
  entityId   String
  before     String?
  after      String?
  metadata   Json?
  createdAt  DateTime            @default(now())

  @@index([projectId, createdAt])
  @@index([actorId, createdAt])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}
// ─── LocalContentOS Content Studio (governed workflow — separate from compliance LocalContent*) ───

model ContentStudioProject {
  id                     String                  @id @default(cuid())
  organizationId         String
  platformOrganizationId String?
  title                  String
  objective              String?
  audience               String?
  language               String                  @default("ar")
  status                 String                  @default("draft")
  createdById            String?
  createdByName          String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  campaigns              ContentStudioCampaign[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([status])
}

model ContentStudioCampaign {
  id               String                @id @default(cuid())
  contentProjectId String
  organizationId   String
  name             String
  objective        String?
  audience         String?
  channels         Json                  @default("[]")
  startDate        String?
  endDate          String?
  status           String                @default("draft")
  createdById      String?
  createdByName    String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  project          ContentStudioProject  @relation(fields: [contentProjectId], references: [id], onDelete: Cascade)
  sources          ContentStudioSource[]
  contentItems     ContentStudioItem[]
  outputs          ContentStudioOutput[]

  @@index([organizationId])
  @@index([contentProjectId])
  @@index([organizationId, status])
  @@index([status])
}

model ContentStudioSource {
  id               String                 @id @default(cuid())
  organizationId   String
  campaignId       String?
  contentItemId    String?
  title            String
  type             String
  url              String?
  note             String?
  fileRef          String?
  credibility      String                 @default("unverified")
  status           String                 @default("proposed")
  evidenceMetadata Json?
  createdById      String?
  createdByName    String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  campaign         ContentStudioCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  contentItem      ContentStudioItem?     @relation(fields: [contentItemId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([campaignId])
  @@index([contentItemId])
  @@index([organizationId, status])
  @@index([status])
}

model ContentStudioItem {
  id                  String                  @id @default(cuid())
  campaignId          String
  organizationId      String
  title               String
  format              String
  body                String?
  sourceRefIds        Json                    @default("[]")
  status              String                  @default("idea")
  aiGenerated         Boolean                 @default(false)
  reviewRequired      Boolean                 @default(false)
  draftAssistMetadata Json?
  createdById         String?
  createdByName       String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  campaign            ContentStudioCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sources             ContentStudioSource[]
  reviews             ContentStudioReview[]
  approvals           ContentStudioApproval[]

  @@index([organizationId])
  @@index([campaignId])
  @@index([organizationId, status])
  @@index([status])
}

model ContentStudioReview {
  id             String            @id @default(cuid())
  contentItemId  String
  organizationId String
  status         String            @default("pending")
  dimensions     Json              @default("{}")
  notes          String?
  reviewerId     String?
  reviewerName   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  contentItem    ContentStudioItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contentItemId])
  @@index([organizationId, status])
  @@index([status])
}

model ContentStudioApproval {
  id             String            @id @default(cuid())
  contentItemId  String
  organizationId String
  approved       Boolean
  notes          String?
  approverId     String?
  approverName   String?
  createdAt      DateTime          @default(now())
  contentItem    ContentStudioItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contentItemId])
}

model ContentStudioOutput {
  id             String                @id @default(cuid())
  campaignId     String
  organizationId String
  title          String
  status         String                @default("draft")
  includes       Json
  exportMetadata Json?
  exportedAt     DateTime?
  createdById    String?
  createdByName  String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  campaign       ContentStudioCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([campaignId])
  @@index([organizationId, status])
  @@index([status])
}
