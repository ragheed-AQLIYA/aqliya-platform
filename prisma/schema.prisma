  @@index([engagementId])
  @@index([status])
  @@index([createdAt])
}

model AuditValidationIssue {
  id              String                       @id @default(cuid())
  validationRunId String
  validationRun   AuditValidationRun           @relation(fields: [validationRunId], references: [id])
