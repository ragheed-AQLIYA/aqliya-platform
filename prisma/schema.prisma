  organizationId   String
  type             IntegrationType
  provider         String
  displayName      String?
  status           IntegrationStatus @default(ACTIVE)
  priority         Int      @default(0)
  vaultSecretId    String?
  configMetadata   Json?
  lastHealthCheckAt DateTime?
  lastSuccessAt    DateTime?
  lastFailureAt    DateTime?
