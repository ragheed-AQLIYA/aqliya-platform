  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([engagementId, checklistItem])
  @@index([engagementId])
}

model AuditValidationRun {
  id             String                 @id @default(cuid())
  engagementId   String
  engagement     AuditEngagement        @relation(fields: [engagementId], references: [id])
  validationType String
  status     String                 @default("completed") // completed | failed | running
  trustState     String                 @default("conditional")
  summary        String?
  issueCount     Int                    @default(0)
  criticalCount  Int                    @default(0)
  highCount      Int                    @default(0)
  mediumCount    Int                    @default(0)
  lowCount       Int                    @default(0)
  createdBy      String
  createdAt      DateTime               @default(now())
  completedAt    DateTime?
