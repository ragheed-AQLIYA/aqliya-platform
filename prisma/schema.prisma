  engagement      AuditEngagement              @relation(fields: [engagementId], references: [id])
  checkType       String
  severity        String
  status          String    @default("open")
  title           String
  description     String
  message         String
  accountCode     String?
  accountName     String?
  expectedValue   Float?
  actualValue     Float?
  difference      Float?
  createdAt       DateTime                     @default(now())
