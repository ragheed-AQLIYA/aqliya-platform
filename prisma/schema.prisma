  @@index([organizationId, status, createdAt])
  @@index([organizationId, requiresLegalReview])
}

// ==================== Intelligence Core — Institutional Memory (IC-01/AGENT-5) ====================

model IntelligenceGraphNode {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           String   // entity | concept | insight | document | topic
  metadata       Json?
  embedding      Unsupported("vector(1536)")?
  embeddingJson  Json?    @map("embedding_json")
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  outgoingEdges IntelligenceGraphEdge[] @relation("IntelligenceGraphNode_outgoing")
  incomingEdges IntelligenceGraphEdge[] @relation("IntelligenceGraphNode_incoming")

  @@index([organizationId, type])
  @@index([organizationId, name])
}

model IntelligenceGraphEdge {
  id             String                @id @default(cuid())
  organizationId String
  sourceId       String
  source         IntelligenceGraphNode @relation("IntelligenceGraphNode_outgoing", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId       String
  target         IntelligenceGraphNode @relation("IntelligenceGraphNode_incoming", fields: [targetId], references: [id], onDelete: Cascade)
  relationType   String                // related_to | derives_from | evidence_for | contradicts | supports | references
  weight         Float                 @default(1.0)
  metadata       Json?
  createdById    String?
  createdAt      DateTime              @default(now())

  @@index([organizationId, sourceId, relationType])
  @@index([organizationId, targetId, relationType])
  @@index([organizationId, relationType])
}

model IntelligenceQuery {
  id             String   @id @default(cuid())
  organizationId String
  query          String
  results        Json?    // array of {chunkId, documentId, similarity, contentPreview}
  resultCount    Int?     @default(0)
  userId         String?
  metadata       Json?    // includes provider, model, latency
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, userId, createdAt])
}

model IngestionBatch {
  id             String   @id @default(cuid())
  organizationId String
  status         String   @default("pending") // pending | processing | completed | failed | partial
  source         String?  // manual_upload | api | webhook | integration
  totalDocuments Int      @default(0)
  processedCount Int      @default(0)
  failedCount    Int      @default(0)
  metadata       Json?
  createdById    String?
  createdAt      DateTime @default(now())
  completedAt    DateTime?
  errorMessage   String?

  documents IngestionDocument[]

  @@index([organizationId, status, createdAt])
}

model IngestionDocument {
  id             String          @id @default(cuid())
  organizationId String
  batchId        String
  batch          IngestionBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  documentId     String          // reference to external document/system ID
  title          String?
  sourceType     String?         // pdf | csv | text | api | email | etc
  status         String          @default("pending") // pending | processing | chunked | embedded | completed | failed
  contentHash    String?         // for deduplication
  totalChunks    Int             @default(0)
  tokenCount     Int?            @default(0)
  metadata       Json?
  createdById    String?
  createdAt      DateTime        @default(now())
  completedAt    DateTime?
  errorMessage   String?

  @@index([organizationId, batchId])
  @@index([organizationId, documentId])
}

// ==================== SSO / NextAuth Adapter Models (L0-05) ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  // oauth | saml | oidc
  provider          String  // google | github | azure-ad | okta | saml | custom-oidc
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== SSO Provider Config (L0-05) ====================

model SsoProvider {
  id                    String   @id @default(cuid())
  organizationId        String
  providerType          String   // oidc | saml | google | github | azure-ad | okta
  label                 String   // display name e.g. "Company Okta"
  issuerUrl             String?  // OIDC issuer URL
  authorizationUrl      String?  // OIDC auth endpoint
  tokenUrl              String?  // OIDC token endpoint
  userInfoUrl           String?  // OIDC userinfo endpoint
  jwksUri               String?  // OIDC JWKS URI
  clientId              String?  // encrypted at rest via PlatformSecret
  clientSecret          String?  // encrypted at rest via PlatformSecret
  samlEntryPoint        String?  // SAML IdP SSO URL
  samlIssuer            String?  // SAML entity ID
  samlCert              String?  // SAML x509 cert
  attributeMapping      Json?    // {email, name, role} field mapping
  domains               Json?    // allowed email domains ["@company.com"]
  enabled               Boolean  @default(true)
  metadata              Json?
  createdById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, providerType, issuerUrl])
  @@index([organizationId, enabled])
}

// ==================== SCIM Provisioning (L0-06) ====================

model ScimProvisioningEvent {
  id              String   @id @default(cuid())
  organizationId  String
  direction       String   // inbound | outbound
  resourceType    String   // User | Group
  operation       String   // POST | PUT | PATCH | DELETE
  externalId      String?  // SCIM external ID
  localId         String?  // local User/Group ID
  requestBody     Json?
  responseStatus  Int?
  responseBody    Json?
  success         Boolean  @default(true)
  errorMessage    String?
  performedById   String?
  createdBy       User?    @relation("ScimEventPerformer", fields: [performedById], references: [id])
  createdAt       DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, resourceType, operation])
}

// ==================== CRM Integration (S7-03) — schema only; not in L0-05 migration ====================

model CrmConnection {
  id              String   @id @default(cuid())
  organizationId  String
  provider        String
  label           String
  apiEndpoint     String?
  accessToken     String?
  refreshToken    String?
  tokenExpiresAt  DateTime?
  apiKey          String?
  apiVersion      String?  @default("v1")
  syncEnabled     Boolean  @default(false)
  syncIntervalMin Int?     @default(60)
  lastSyncAt      DateTime?
  lastSyncStatus  String?
  lastSyncError   String?
  fieldMapping    Json?
  conflictPolicy  String?  @default("crm_wins")
  metadata        Json?
  createdById     String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  syncLogs     CrmSyncLog[]

  @@index([organizationId, provider])
  @@index([organizationId, syncEnabled])
}

model CrmSyncLog {
  id             String   @id @default(cuid())
  connectionId   String
  connection     CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  organizationId String
  resourceType   String
  direction      String
  status         String
  totalRecords   Int      @default(0)
  createdRecords Int      @default(0)
  updatedRecords Int      @default(0)
  failedRecords  Int      @default(0)
  skippedRecords Int      @default(0)
  errorDetails   Json?
  createdAt      DateTime @default(now())
  completedAt    DateTime?

  @@index([connectionId, createdAt])
  @@index([organizationId, status, createdAt])
}

// ==================== ERP Integration (LC-08) — schema only; not in L0-05 migration ====================

model ErpConnection {
  id                String   @id @default(cuid())
  organizationId    String
  provider          String
  label             String
  connectionType    String   @default("api")
  apiEndpoint       String?
  apiKey            String?
