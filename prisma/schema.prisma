  rationale    String?
  disposedBy   String
  disposedAt   DateTime             @default(now())

  @@index([issueId])
  @@index([engagementId])
}

// ==================== Sunbul Models ====================

enum SunbulUserRole {
  PlatformAdmin
  Operator
  Reviewer
}

enum SunbulMembershipStatus {
  Active
  Suspended
}

enum SunbulRecordStatus {
  Draft
  UnderReview
  Approved
  Archived
}

enum SunbulReviewStatus {
  Pending
  Approved
  Returned
}

enum SunbulAuditAction {
  CLIENT_CREATED
  CLIENT_UPDATED
  MEMBERSHIP_CREATED
  MEMBERSHIP_ROLE_CHANGED
  MEMBERSHIP_STATUS_CHANGED
  RECORD_CREATED
  RECORD_UPDATED
  RECORD_SUBMITTED
  RECORD_APPROVED
  RECORD_RETURNED
  RECORD_ARCHIVED
  RECORD_EXPORTED
  REVIEW_CREATED
  DOCUMENT_CREATED
  DOCUMENT_DELETED
}

model SunbulClient {
  id                     String   @id @default(cuid())
  name                   String
  slug                   String   @unique
  status                 String   @default("active")
  config                 Json?
  platformOrganizationId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  platformOrganization PlatformOrganization? @relation(fields: [platformOrganizationId], references: [id])
  memberships          SunbulUserMembership[]
  records              SunbulRecord[]
  documents            SunbulDocument[]
  reviews              SunbulReview[]
  auditEvents          SunbulAuditEvent[]

  @@index([status])
  @@index([createdAt])
  @@index([platformOrganizationId])
}

model SunbulUserMembership {
  id        String                 @id @default(cuid())
  clientId  String
  client    SunbulClient           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String
  role      SunbulUserRole         @default(Operator)
  status    SunbulMembershipStatus @default(Active)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@unique([clientId, userId])
  @@index([clientId])
  @@index([userId])
  @@index([role])
}

model SunbulRecord {
  id          String             @id @default(cuid())
  clientId    String
  client      SunbulClient       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        String             @default("CASE")
  status      SunbulRecordStatus @default(Draft)
  priority    String             @default("medium")
  createdById String
  submittedAt DateTime?
  approvedAt  DateTime?
  archivedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  documents SunbulDocument[]
  reviews   SunbulReview[]

  @@index([clientId])
  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

model SunbulDocument {
  id           String       @id @default(cuid())
  clientId     String
  client       SunbulClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recordId     String
  record       SunbulRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  fileName     String
  fileType     String
  fileSize     Int          @default(0)
  storageKey   String
  uploadedById String
  createdAt    DateTime     @default(now())

  @@index([clientId])
  @@index([recordId])
  @@index([uploadedById])
}

model SunbulReview {
  id         String             @id @default(cuid())
  clientId   String
  client     SunbulClient       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recordId   String
  record     SunbulRecord       @relation(fields: [recordId], references: [id], onDelete: Cascade)
  reviewerId String
  status     SunbulReviewStatus @default(Pending)
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([clientId])
  @@index([recordId])
  @@index([reviewerId])
}

model SunbulAuditEvent {
  id         String            @id @default(cuid())
  clientId   String
  client     SunbulClient      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recordId   String?
  actorId    String
  action     SunbulAuditAction
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime          @default(now())

  @@index([clientId])
  @@index([recordId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

