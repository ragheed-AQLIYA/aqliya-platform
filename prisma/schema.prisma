// ==================== AuditOS 2.0 Reporting Graph (Phase 2) ====================

model ReportingGraph {
  id           String         @id @default(cuid())
  engagementId String         @unique
  engagement   AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  version      Int            @default(1)
  nodes        ReportingGraphNode[]
  edges        ReportingGraphEdge[]
  snapshots    ReportingGraphSnapshot[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([engagementId])
}

model ReportingGraphNode {
  id         String         @id @default(cuid())
  graphId    String
  graph      ReportingGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)
  nodeType   String
  entityType String
  entityId   String
  label      String
  metadata   Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  outgoingEdges ReportingGraphEdge[] @relation("ReportingGraphEdgeSource")
  incomingEdges ReportingGraphEdge[] @relation("ReportingGraphEdgeTarget")

  @@unique([graphId, entityType, entityId])
  @@index([graphId, nodeType])
}

model ReportingGraphEdge {
  id           String             @id @default(cuid())
  graphId      String
  graph        ReportingGraph     @relation(fields: [graphId], references: [id], onDelete: Cascade)
  edgeType     String
  sourceNodeId String
  targetNodeId String
  sourceNode   ReportingGraphNode @relation("ReportingGraphEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode   ReportingGraphNode @relation("ReportingGraphEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  metadata     Json?
  createdAt    DateTime           @default(now())

  @@unique([graphId, edgeType, sourceNodeId, targetNodeId])
  @@index([graphId])
}

model ReportingGraphSnapshot {
  id        String         @id @default(cuid())
  graphId   String
  graph     ReportingGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)
  milestone String
  nodeCount Int            @default(0)
  edgeCount Int            @default(0)
  payload   Json
  createdAt DateTime       @default(now())

  @@index([graphId, createdAt])
}

model AuditTrialBalance {
