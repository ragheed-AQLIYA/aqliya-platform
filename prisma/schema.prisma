// ==================== Intelligence Core — RAG (IC-01 pgvector) ====================
// Embedding storage strategy:
// - `embedding` (vector(1536)): primary when pgvector extension is available
// - `embeddingJson` (Json?): fallback when pgvector is not installed
// Use isPgvectorAvailable() from pgvector-compat to check at runtime.
// Similarity search requires pgvector; without it, use application-level filtering.

model DocumentChunk {
  id             String                      @id @default(cuid())
  organizationId String
  documentId     String
  chunkIndex     Int
  content        String
  tokenCount     Int?
  metadata       Json?
  embedding      Unsupported("vector(1536)")?
  embeddingJson  Json?                       @map("embedding_json")
  createdBy      String?
  createdAt      DateTime                    @default(now())

  @@index([organizationId, documentId])
  @@index([organizationId, chunkIndex])
}

