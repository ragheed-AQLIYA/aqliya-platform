generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

enum DecisionStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum DecisionType {
  TENDER
  INVESTMENT
  EXPANSION
  PROCUREMENT
  HIRING
  PARTNERSHIP
  PRICING
  STRATEGIC
  OPERATIONS
  CUSTOM
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ScenarioType {
  BEST_CASE
  EXPECTED_CASE
  WORST_CASE
}

enum RecommendationType {
  GO
  GO_WITH_CONDITIONS
  NO_GO
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OutcomeStatus {
  SUCCESS
  PARTIAL_SUCCESS
  FAILURE
  UNKNOWN
}

enum AuditAction {
  DECISION_CREATED
  DECISION_UPDATED
  RECOMMENDATION_UPDATED
  PATTERN_EXTRACTED
  ALERT_RESOLVED
  SECTOR_ASSIGNED
  BENCHMARK_CREATED
  OUTPUT_PUBLISHED
  OUTPUT_UNPUBLISHED
  SUBMITTED_FOR_REVIEW
  DECISION_APPROVED
  DECISION_APPROVED_WITH_CONDITIONS
  DECISION_REJECTED
  REVISION_REQUESTED
  SNAPSHOT_PUBLISHED
  CURRENT_PUBLISHED_WITHOUT_APPROVAL
  STALE_PUBLISH_BLOCKED
  STALE_PUBLISH_OVERRIDE
  OUTCOME_CREATED
  OUTCOME_UPDATED
  OUTCOME_REVIEWED
}

// ==================== Platform Organization (Bridge) ====================

model PlatformOrganization {
  // @map: المنظمات_المنصة
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  displayName String?
  status      String   @default("active")
  metadata    Json?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizations      Organization[]      @relation("OrgPlatformOrg")
  auditOrganizations AuditOrganization[] @relation("AuditOrgPlatformOrg")
  clientWorkspaces   ClientWorkspace[]
  sunbulClients      SunbulClient[]
  @@index([createdAt])
}

// ==================== ClientWorkspace & Project ====================

model ClientWorkspace {
  id                     String               @id @default(cuid())
  platformOrganizationId String
  platformOrganization   PlatformOrganization @relation(fields: [platformOrganizationId], references: [id])
  name                   String
  slug                   String
  workspaceType          String               @default("client") // client | internal | content | decision
  status                 String               @default("active") // active | archived | suspended
  productAccess          Json?
  metadata               Json?
  createdById            String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  deletedAt              DateTime?

  projects     Project[]
  auditClients AuditClient[]

  @@unique([platformOrganizationId, slug])
  @@index([platformOrganizationId, status])
  @@index([workspaceType])
  @@index([status])
  @@index([deletedAt])
}

model Project {
  id          String          @id @default(cuid())
  workspaceId String
  workspace   ClientWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  projectType String
  status      String          @default("active") // active | archived | completed
  team        Json?
  metadata    Json?
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  auditEngagements AuditEngagement[]

  @@index([workspaceId, status])
  @@index([projectType])
  @@index([status])
  @@index([createdAt])
}

// ==================== Platform Audit Log ====================

model PlatformAuditLog {
  id                     String   @id @default(cuid())
  platformOrganizationId String?
  clientWorkspaceId      String?
  projectId              String?
  productKey             String
  environment            String?
  actorId                String?
  actorType              String?
  actorEmail             String?
  actorName              String?
  action                 String
  targetType             String?
  targetId               String?
  targetLabel            String?
  severity               String   @default("info")
  status                 String   @default("recorded")
  sourceSystem           String?
  sourceModel            String?
  sourceId               String?
  requestId              String?
  sessionId              String?
  ipAddress              String?
  userAgent              String?
  aiProvider             String?
  aiModel                String?
  aiPromptVersion        String?
  aiOutputReviewStatus   String?
  evidenceRefs           Json?
  metadata               Json?
  createdAt              DateTime @default(now())

  @@index([platformOrganizationId, createdAt])
  @@index([clientWorkspaceId, createdAt])
  @@index([projectId, createdAt])
  @@index([productKey, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@index([sourceSystem, sourceId])
  @@index([createdAt])
}

// ==================== Office AI Assistant (Shared Application) ====================

model OfficeAiTask {
  id                     String    @id @default(cuid())
  platformOrganizationId String
  clientWorkspaceId      String?
  projectId              String?
  taskType               String // summarize | analyze | draft | outline | exec_summary | meeting_notes
  status                 String    @default("draft") // draft | finalized | rejected | archived
  language               String    @default("ar") // ar | en
  title                  String?
  instructions           String?
  createdById            String?
  createdByName          String?
  reviewedById           String?
  reviewedAt             DateTime?
  approvedById           String?
  approvedAt             DateTime?
  metadata               Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  outputs     OfficeAiOutput[]
  sourceFiles OfficeAiFile[]

  @@index([platformOrganizationId, createdAt])
  @@index([clientWorkspaceId, createdAt])
  @@index([projectId, createdAt])
  @@index([taskType, createdAt])
  @@index([status, createdAt])
  @@index([createdById, createdAt])
}

model OfficeAiOutput {
  id              String       @id @default(cuid())
  taskId          String
  task            OfficeAiTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  content         String
  format          String       @default("markdown") // markdown | text | html
  status          String       @default("draft") // draft | finalized | rejected
  aiProvider      String       @default("deterministic") // deterministic | cloud_ai | local_ai
  aiModel         String?
  aiPromptVersion String?
  confidenceScore Float?
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([taskId, createdAt])
  @@index([status, createdAt])
}

model OfficeAiFile {
  id           String       @id @default(cuid())
  taskId       String
  task         OfficeAiTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  filename     String
  fileType     String // pdf | docx | xlsx | csv | txt | md
  mimeType     String?
  storageKey   String?
  fileHash     String?
  sizeBytes    Int?
  uploadedById String?
  metadata     Json?
  createdAt    DateTime     @default(now())

  extractedContent String?   @db.Text
  extractionMeta   Json?
  extractedAt      DateTime?
  extractionStatus String?

  @@index([taskId, createdAt])
  @@index([fileHash])
}

model Organization {
  // @map: المنظمات
  id               String                     @id @default(cuid())
  name             String
  users            User[]
  decisions        Decision[]
  auditLogs        AuditLog[]
  signals          DecisionMonitoringSignal[]
  alerts           DecisionRiskAlert[]
  decisionPatterns DecisionPattern[]
  reports          DecisionReport[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  platformOrganizationId String?
  platformOrganization   PlatformOrganization? @relation("OrgPlatformOrg", fields: [platformOrganizationId], references: [id])

  @@index([createdAt])
  @@index([platformOrganizationId])
}

model User {
  id                       String            @id @default(cuid())
  email                    String            @unique
  name                     String
  passwordHash             String?
  role                     UserRole          @default(OPERATOR)
  organizationId           String
  organization             Organization      @relation(fields: [organizationId], references: [id])
  ownedDecisions           Decision[]        @relation("DecisionOwner")
  reviewedDecisions        Decision[]        @relation("DecisionReviewer")
  approvedDecisions        Decision[]        @relation("DecisionApprover")
  approvals                Approval[]        @relation("ApprovalApprover")
  reviewedOutcomes         DecisionOutcome[] @relation("OutcomeReviewer")
  auditLogs                AuditLog[]
  publishedRecommendations Recommendation[]  @relation("RecommendationPublisher")
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@index([organizationId])
  @@index([role])
}

model Decision {
  // @map: القرارات
  id                String                     @id @default(cuid())
  title             String
  type              DecisionType               @default(TENDER)
  ownerId           String
  owner             User                       @relation("DecisionOwner", fields: [ownerId], references: [id])
  reviewerId        String?
  reviewer          User?                      @relation("DecisionReviewer", fields: [reviewerId], references: [id])
  approverId        String?
  approver          User?                      @relation("DecisionApprover", fields: [approverId], references: [id])
  organizationId    String
  organization      Organization               @relation(fields: [organizationId], references: [id])
  status            DecisionStatus             @default(DRAFT)
  description       String?
  priority          String                     @default("MEDIUM")
  targetDate        DateTime?
  tenderProfile     TenderProfile?
  objectives        Objective[]
  constraints       Constraint[]
  assumptions       Assumption[]
  alternatives      Alternative[]
  risks             Risk[]
  framework         DecisionFramework?
  decisionScenarios DecisionScenario[]
  riskAnalyses      DecisionRiskAnalysis[]
  scenarios         Scenario[]
  simulations       SimulationResult[]
  recommendation    Recommendation?
  approvals         Approval[]
  outcome           DecisionOutcome?
  auditLogs         AuditLog[]
  reports           DecisionReport[]
  signals           DecisionMonitoringSignal[]
  alerts            DecisionRiskAlert[]
  // A-3: Sector assignment
  sectorId          String?
  sector            Sector?                    @relation(fields: [sectorId], references: [id])
  decisionPatterns  DecisionPattern?
  sectorPatterns    SectorPattern[] // Added opposite relation for SectorPattern
  evidence          DecisionEvidence[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([ownerId])
  @@index([createdAt])
  @@index([type])
}

model DecisionFramework {
  id              String   @id @default(cuid())
  decisionId      String   @unique
  decision        Decision @relation(fields: [decisionId], references: [id])
  context         String
  purpose         String
  options         String
  criteria        String
  values          String
  informationGaps String
  certainty       String
  assumptions     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DecisionScenario {
  id                   String                @id @default(cuid())
  decisionId           String
  decision             Decision              @relation(fields: [decisionId], references: [id])
  riskAnalysis         DecisionRiskAnalysis?
  name                 String
  description          String
  assumptions          String
  expectedOutcome      String
  affectedStakeholders String
  requiredConditions   String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([decisionId])
}

model DecisionRiskAnalysis {
  id               String           @id @default(cuid())
  decisionId       String
  decision         Decision         @relation(fields: [decisionId], references: [id])
  scenarioId       String           @unique
  scenario         DecisionScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  risks            String
  tradeoffs        String
  sacrifices       String
  opportunityCosts String
  stakeholderRisks String
  operationalRisks String
  strategicRisks   String
  knowledgeRisks   String
  uncertaintyLevel String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([decisionId])
}

model Objective {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id])
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([decisionId])
}

model Constraint {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id])
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([decisionId])
}

model Assumption {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id])
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([decisionId])
}

model Alternative {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id])
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([decisionId])
}

model Risk {
  id          String    @id @default(cuid())
  decisionId  String
  decision    Decision  @relation(fields: [decisionId], references: [id])
  description String
  level       RiskLevel
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([decisionId])
}

model TenderProfile {
  id                        String    @id @default(cuid())
  decisionId                String    @unique
  decision                  Decision  @relation(fields: [decisionId], references: [id])
  clientName                String
  estimatedContractValue    Float
  estimatedCost             Float
  durationMonths            Int
  requiredCapacity          Int
  internalAvailableCapacity Int
  strategicFitScore         Int
  riskLevel                 RiskLevel
  marginEstimate            Float
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
}

model Scenario {
  id         String            @id @default(cuid())
  decisionId String
  decision   Decision          @relation(fields: [decisionId], references: [id])
  type       ScenarioType
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  simulation SimulationResult?

  @@unique([decisionId, type])
  @@index([decisionId])
}

model SimulationResult {
  id                   String    @id @default(cuid())
  decisionId           String
  decision             Decision  @relation(fields: [decisionId], references: [id])
  scenarioId           String?   @unique
  scenario             Scenario? @relation(fields: [scenarioId], references: [id])
  feasibilityScore     Float
  financialScore       Float
  capacityScore        Float
  riskScore            Float
  strategicFitScore    Float
  overallDecisionScore Float
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([decisionId])
}

model DecisionMonitoringSignal {
  id             String              @id @default(cuid())
  decisionId     String
  decision       Decision            @relation(fields: [decisionId], references: [id])
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id])
  // Required: source of signal
  source         String // "assumption" | "risk" | "scenario" | "execution"
  // Required: link to A-1 entity
  referenceId    String // ID of the assumption/risk/scenario that triggered this
  signalType     String // e.g., "risk-increased", "assumption-invalidated"
  description    String
  severity       SignalSeverity      @default(INFO)
  status         SignalStatus        @default(NEW)
  // No manual creation - system only
  generatedBy    String              @default("system") //Always "system"
  acknowledgedBy String?
  acknowledgedAt DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  // Opposite relation for alerts triggered by this signal
  alerts         DecisionRiskAlert[]

  @@index([organizationId])
}

model DecisionRiskAlert {
  id                 String                   @id @default(cuid())
  decisionId         String
  decision           Decision                 @relation(fields: [decisionId], references: [id])
  organizationId     String
  organization       Organization             @relation(fields: [organizationId], references: [id])
  // Required: what triggered this alert
  triggeringSignalId String                   @unique
  triggeringSignal   DecisionMonitoringSignal @relation(fields: [triggeringSignalId], references: [id])
  alertType          String // e.g., "scenario-risk-emerged", "assumption-invalidated"
  description        String
  severity           AlertSeverity            @default(MEDIUM)
  status             AlertStatus              @default(OPEN)
  // Must always require human review
  requiresReview     Boolean                  @default(true)
  // Never auto-resolve
  reviewedBy         String?
  reviewedAt         DateTime?
  resolution         String? // Only set after human review
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([organizationId])
}

enum SignalSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
}

enum SignalStatus {
  NEW
  ACKNOWLEDGED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED // Only after human review, never auto
}

model Recommendation {
  id                    String     @id @default(cuid())
  decisionId            String     @unique
  decision              Decision   @relation(fields: [decisionId], references: [id])
  recommendedAction     String
  rationale             String
  expectedNextState     String
  scopeExclusions       String
  assumptionsUsed       String
  risksAccepted         String
  risksRejected         String
  humanReviewRequired   Boolean    @default(true)
  isClientVisible       Boolean    @default(false)
  publishedAt           DateTime?
  publishedById         String?
  publishedBy           User?      @relation("RecommendationPublisher", fields: [publishedById], references: [id])
  publishedVersion      Int        @default(1)
  publishedFromSnapshot Boolean    @default(false)
  publishedApprovalId   String?
  approvals             Approval[]
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([publishedAt])
}

model Approval {
  id                        String          @id @default(cuid())
  decisionId                String
  decision                  Decision        @relation(fields: [decisionId], references: [id])
  approverId                String
  approver                  User            @relation("ApprovalApprover", fields: [approverId], references: [id])
  status                    ApprovalStatus  @default(PENDING)
  comments                  String?
  recommendationId          String?
  recommendation            Recommendation? @relation(fields: [recommendationId], references: [id])
  snapshotAction            String?
  snapshotRationale         String?
  snapshotExpectedNextState String?
  snapshotScopeExclusions   String?
  snapshotAssumptionsUsed   String?
  snapshotRisksAccepted     String?
  snapshotRisksRejected     String?
  snapshotConditions        String?
  snapshotRisks             Json?
  snapshotNextActions       Json?
  snapshotConfidence        Float?
  snapshotScore             Float?
  snapshotOverrideReason    String?
  snapshotCreatedAt         DateTime?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  @@index([decisionId])
  @@index([approverId])
  @@index([status])
}

model DecisionOutcome {
  id              String        @id @default(cuid())
  decisionId      String        @unique
  decision        Decision      @relation(fields: [decisionId], references: [id])
  expectedOutcome String
  actualOutcome   String?
  outcomeStatus   OutcomeStatus @default(UNKNOWN)
  actualValue     Float?
  expectedValue   Float?
  variance        Float?
  lessonsLearned  String?
  followUpActions Json?
  reviewedById    String?
  reviewedBy      User?         @relation("OutcomeReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([outcomeStatus])
}

model AuditLog {
  id             String       @id @default(cuid())
  decisionId     String
  decision       Decision     @relation(fields: [decisionId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  action         AuditAction
  entity         String?
  before         String?
  after          String?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

// ==================== A-3 Intelligence Layer ====================

model Sector {
  id          String  @id @default(cuid())
  name        String  @unique
  description String
  code        String  @unique
  isActive    Boolean @default(true)

  // Relations
  benchmarks SectorBenchmark[]
  patterns   SectorPattern[]
  playbooks  SectorPlaybook[]
  rules      SectorRule[]
  decisions  Decision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model SectorBenchmark {
  id       String @id @default(cuid())
  sectorId String
  sector   Sector @relation(fields: [sectorId], references: [id])

  metricName    String
  value         Float
  unit          String
  benchmarkType String

  // Per A-3 design: not static
  sourceType String @default("manual") // "manual" | "derived" | "assumption"
  confidence Float  @default(1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectorId, metricName, benchmarkType])
  @@index([sectorId])
}

model SectorPattern {
  id       String @id @default(cuid())
  sectorId String
  sector   Sector @relation(fields: [sectorId], references: [id])

  patternType String
  patternKey  String

  // Incremental fields
  occurrenceCount Int      @default(1)
  lastObservedAt  DateTime @default(now())
  confidenceScore Float

  sourceDecisionId String?
  sourceDecision   Decision? @relation(fields: [sourceDecisionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectorId, patternType, patternKey])
  @@index([sectorId])
}

model DecisionPattern {
  id             String       @id @default(cuid())
  decisionId     String       @unique
  decision       Decision     @relation(fields: [decisionId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  patternScope String @default("DECISION") // "DECISION" | "SECTOR" | "CROSS_SECTOR"

  extractedAt DateTime @default(now())
  confidence  Float

  // No raw analysis stored in DB

  @@index([organizationId])
}

model SectorPlaybook {
  id       String @id @default(cuid())
  sectorId String
  sector   Sector @relation(fields: [sectorId], references: [id])

  title        String
  content      String
  playbookType String
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectorId])
}

model SectorRule {
  id       String @id @default(cuid())
  sectorId String
  sector   Sector @relation(fields: [sectorId], references: [id])

  ruleName            String
  condition           String
  action              String
  isActive            Boolean @default(false)
  requiresHumanReview Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectorId])
}

model DecisionReport {
  id             String       @id @default(cuid())
  decisionId     String
  decision       Decision     @relation(fields: [decisionId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  title          String
  content        Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

// ==================== Decision Evidence ====================

model DecisionEvidence {
  id             String    @id @default(cuid())
  decisionId     String
  decision       Decision  @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  organizationId String
  filename       String
  fileType       String
  fileSize       Int       @default(0)
  fileHash       String?
  storageKey     String?
  uploadedById   String?
  description    String?
  metadata       Json?
  createdAt      DateTime  @default(now())

  @@index([decisionId])
  @@index([organizationId])
  @@index([createdAt])
}

// ==================== AuditOS Models ====================

model AuditOrganization {
  // @map: مؤسسات_المراجعة
  id                  String        @id @default(cuid())
  name                String
  slug                String        @unique
  jurisdiction        String
  regulatoryFramework String
  governanceRules     Json?
  status              String        @default("active")
  clients             AuditClient[]
  users               AuditUser[]
  createdById         String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  platformOrganizationId String?
  platformOrganization   PlatformOrganization? @relation("AuditOrgPlatformOrg", fields: [platformOrganizationId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([platformOrganizationId])
}

model AuditUser {
  id             String            @id @default(cuid())
  organizationId String
  organization   AuditOrganization @relation(fields: [organizationId], references: [id])
  email          String
  name           String
  role           String            @default("operator")
  status         String            @default("active")
  lastLoginAt    DateTime?
  createdById    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId, status])
}

model AuditClient {
  // @map: عملاء_المراجعة
  id                 String            @id @default(cuid())
  organizationId     String
  organization       AuditOrganization @relation(fields: [organizationId], references: [id])
  name               String
  registrationNumber String?
  industry           String
  reportingFramework String            @default("ifrs_for_smes")
  fiscalPeriodEnd    String            @default("12-31")
  currencyCode       String            @default("SAR")
  status             String            @default("active")
  contactEmail       String?
  contactPhone       String?
  engagements        AuditEngagement[]
  createdById        String?
  createdAt          DateTime          @default(now())
