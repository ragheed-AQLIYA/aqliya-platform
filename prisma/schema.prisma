  subject                String?
  summary                String?
  occurredAt             DateTime
  duration               Int?         // minutes
  metadata               Json?
  createdById            String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([organizationId, contactId, occurredAt])
  @@index([organizationId, interactionType, occurredAt])
  @@index([platformOrganizationId, createdAt])
