model WorkflowAuditEvent {
  id                     String   @id @default(cuid())
  organizationId         String
  platformOrganizationId String?
  recordId               String
  actorId                String
  actorName              String?
  action                 String   // created | advanced | completed | rejected | cancelled | assigned | updated
  fromStatus             String?
  toStatus               String?
  comment                String?
  metadata               Json?
  createdAt              DateTime @default(now())

  @@index([organizationId, recordId, createdAt])
  @@index([organizationId, actorId, createdAt])
  @@index([platformOrganizationId, createdAt])
}

model WorkflowEvidence {
  id                     String   @id @default(cuid())
  organizationId         String
  platformOrganizationId String?
  recordId               String
  stepIndex              Int?
  filename               String
  fileType               String
  storageKey             String?
  fileHash               String?
  sizeBytes              Int?
  uploadedById           String?
  description            String?
  metadata               Json?
  createdAt              DateTime @default(now())

  @@index([organizationId, recordId, createdAt])
  @@index([platformOrganizationId, createdAt])
}

// ─── LocalContactOS L4.5: Evidence + Review + Approval ──────────────────

model ContactEvidence {
  id                     String       @id @default(cuid())
  organizationId         String
  platformOrganizationId String?
  contactId              String
  contact                LocalContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  filename               String
  fileType               String
  storageKey             String?
  fileHash               String?
  sizeBytes              Int?
  description            String?
  evidenceType           String       @default("document") // document | note | reference | attachment
  uploadedById           String?
  metadata               Json?
  createdAt              DateTime     @default(now())

  @@index([organizationId, contactId, createdAt])
  @@index([platformOrganizationId, createdAt])
}

model ContactReview {
  id                     String           @id @default(cuid())
  organizationId         String
  platformOrganizationId String?
  contactId              String
  contact                LocalContact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  reviewType             String           @default("sensitivity") // sensitivity | accuracy | completeness | custom
  status                 String           @default("pending") // pending | approved | changes_requested | rejected
  reviewerId             String
  reviewerName           String?
  reason                 String?
  findings               Json?            @default("[]")
  reviewerNotes          String?
  reviewDueDate          DateTime?
  completedAt            DateTime?
  metadata               Json?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  approvals ContactApproval[]

  @@index([organizationId, contactId, createdAt])
  @@index([organizationId, status, createdAt])
  @@index([reviewerId, status])
}

model ContactApproval {
  id                     String         @id @default(cuid())
  organizationId         String
  platformOrganizationId String?
  reviewId               String
  review                 ContactReview   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  approverId             String
  approverName           String?
  status                 String         @default("approved") // approved | rejected
  note                   String?
  metadata               Json?
  createdAt              DateTime       @default(now())

  @@index([organizationId, reviewId])
  @@index([approverId])
}

// ─── LocalContactOS L5: Export + Compliance ──────────────────────────────

model ContactExportRequest {
  id                     String        @id @default(cuid())
  organizationId         String
  platformOrganizationId String?
  contactId              String
  contact                LocalContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status                 String        @default("pending") // pending | approved | rejected
  requestedById          String
  requestedByName        String?
  reason                 String?
  reviewedById           String?
  reviewedByName         String?
  reviewNote             String?
  reviewedAt             DateTime?
  requiresLegalReview    Boolean       @default(false)
  legalReviewStatus      String?       // not_required | pending | cleared | blocked
  exportedAt             DateTime?
  metadata               Json?
  createdAt              DateTime      @default(now())
