// ==================== TB Intelligence — Firm Memory (ADR-001) ====================

enum TBMappingPatternStatus {
  DRAFT
  CONFIRMED
  TRUSTED
  DEPRECATED
}

model TBMappingPattern {
  id                   String                   @id @default(cuid())
  organizationId       String
  clientAccountCode    String
  clientAccountName    String?
  /** Normalised account name for secondary lookup (Phase 3C). */
  nameFingerprint      String?
  erpMap1Label         String?
  erpMap2Label         String?
  canonicalAccountId   String
  hitCount             Int                      @default(1)
  lastConfidence       Float?
  lastUsedAt           DateTime                 @default(now())
  lastConfirmedById    String?
  lastConfirmedAt      DateTime?
  lastEngagementId     String?
  /** Phase 3D — unique reviewer IDs who confirmed this pattern. */
  confirmedReviewerIds Json                     @default("[]")
  /** Phase 3D — governance lifecycle status. */
  status               TBMappingPatternStatus   @default(CONFIRMED)
  auditClientId        String?
  erpChartKey          String?
  memoryVersion        Int                      @default(1)
  deprecatedAt         DateTime?
  deprecatedReason     String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, clientAccountCode])
  @@index([organizationId])
  @@index([organizationId, nameFingerprint])
  @@index([organizationId, erpMap1Label, erpMap2Label])
  @@index([organizationId, status])
  @@index([auditClientId])
}

model TBMappingFeedback {
  id                   String   @id @default(cuid())
  organizationId       String
  engagementId         String?
  clientAccountCode    String
  erpMap1Label         String?
  erpMap2Label         String?
  suggestedCanonicalId String?
  acceptedCanonicalId  String
  wasAccepted          Boolean
  reviewerId           String
  createdAt            DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([engagementId])
}

model TBClassificationHistory {
  id             String   @id @default(cuid())
  organizationId String
  engagementId   String?
  accountCode    String
  accountName    String?
  resultCategory String
  canonicalCode  String?
  confidence     Float
  source         String
  providerId     String?
  mappingHints   Json?
  /** Phase 4 — explainable classification snapshot (Trust + Evidence). */
  classificationDetail Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([engagementId])
  @@index([accountCode])
}

// ==================== Attribute-Based Access Control (ABAC) ====================

enum AbacEffect {
  ALLOW
  DENY
}

enum AbacOperator {
  EQ
  NEQ
  GT
  GTE
  LT
  LTE
  IN
  NOT_IN
  CONTAINS
  NOT_CONTAINS
  STARTS_WITH
  ENDS_WITH
  EXISTS
}

model AbacPolicy {
  id             String   @id @default(cuid())
  organizationId String?
  name           String
  description    String?
  resourceType   String
  effect         AbacEffect @default(ALLOW)
  priority       Int        @default(100)
  isActive       Boolean    @default(true)
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization?       @relation(fields: [organizationId], references: [id])
  conditions  AbacPolicyCondition[]
  assignments AbacPolicyAssignment[]

  @@index([organizationId, resourceType])
  @@index([isActive])
}

model AbacPolicyCondition {
  id        String   @id @default(cuid())
  policyId  String
  attribute String
  operator  AbacOperator
  value     String
  createdBy String?
  createdAt DateTime @default(now())

  policy AbacPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
}

model AbacPolicyAssignment {
  id        String   @id @default(cuid())
  policyId  String
  roleId    String?
  userId    String?
  createdAt DateTime @default(now())

  policy AbacPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@index([roleId, userId])
}

