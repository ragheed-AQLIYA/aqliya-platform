    {
      "ruleId": "ias-23-r003",
      "paragraphReference": "IAS 23.17",
      "ruleText": "Capitalisation shall commence when expenditures for the asset are being incurred, borrowing costs are being incurred, and activities to prepare the asset are in progress.",
