    {
      "ruleId": "ifrs9-r003",
      "paragraphReference": "IFRS 9.5.1.1",
      "ruleText": "An entity shall measure financial liabilities at amortised cost using the effective interest method, except for liabilities designated at fair value through profit or loss or arising from transfers that do not qualify for derecognition.",
