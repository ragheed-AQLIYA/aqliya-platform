        "authority": "ifrs-foundation",
        "usage": "mapping-engine"
      }
    },
    {
      "ruleId": "ifrs15-r006",
      "paragraphReference": "IFRS 15.B3-B4",
      "ruleText": "Revenue is recognised when (or as) the entity satisfies a performance obligation by transferring a promised good or service — over time if criteria in paragraph 35 are met, otherwise at a point in time.",
      "topic": "revenue-recognition-timing",
