        "usage": "mapping-engine"
      }
    },
    {
      "ruleId": "ifrs15-r002",
      "paragraphReference": "IFRS 15.31",
      "ruleText": "An entity shall account for a contract with a customer only when specified criteria are met, including approval and identification of rights, payment terms, commercial substance, and probable collection of consideration.",
      "topic": "contract-identification",
      "assetType": "A",
      "lineageParentId": "kf-accounting-a-ifrs-15",
      "confidenceScore": 95,
      "validationStatus": "validated",
      "ontology": {
        "domain": "accounting",
        "subdomain": "ifrs-standards",
        "entity": "standard",
        "relationship": "implements",
        "authority": "ifrs-foundation",
        "usage": "mapping-engine"
      }
    },
    {
      "ruleId": "ifrs15-r003",
      "paragraphReference": "IFRS 15.35",
      "ruleText": "At contract inception, an entity shall assess the goods or services promised and identify as performance obligations each distinct good or service or bundle of goods or services.",
      "topic": "performance-obligations",
      "assetType": "A",
      "lineageParentId": "kf-accounting-a-ifrs-15",
      "confidenceScore": 95,
      "validationStatus": "validated",
      "ontology": {
        "domain": "accounting",
        "subdomain": "ifrs-standards",
        "entity": "standard",
        "relationship": "implements",
        "authority": "ifrs-foundation",
        "usage": "mapping-engine"
      }
    },
    {
      "ruleId": "ifrs15-r004",
      "paragraphReference": "IFRS 15.38",
      "ruleText": "A good or service is distinct if the customer can benefit from it on its own or with readily available resources and it is separately identifiable from other promises in the contract.",
      "topic": "distinct-goods-services",
      "assetType": "A",
      "lineageParentId": "kf-accounting-a-ifrs-15",
      "confidenceScore": 95,
      "validationStatus": "validated",
      "ontology": {
        "domain": "accounting",
        "subdomain": "ifrs-standards",
        "entity": "standard",
        "relationship": "implements",
        "authority": "ifrs-foundation",
        "usage": "mapping-engine"
      }
    },
    {
      "ruleId": "ifrs15-r005",
      "paragraphReference": "IFRS 15.46",
      "ruleText": "An entity shall allocate the transaction price to each performance obligation in proportion to the stand-alone selling prices of the distinct goods or services underlying each performance obligation.",
      "topic": "transaction-price-allocation",
      "assetType": "A",
      "lineageParentId": "kf-accounting-a-ifrs-15",
      "confidenceScore": 95,
      "validationStatus": "validated",
