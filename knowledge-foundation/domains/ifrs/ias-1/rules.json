      "ruleId": "ias1-r003",
      "paragraphReference": "IAS 1.25",
      "ruleText": "An entity shall not offset assets and liabilities or income and expenses unless offsetting is required or permitted by an IFRS Accounting Standard.",
      "topic": "no-offsetting",
