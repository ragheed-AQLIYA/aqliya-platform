      "ruleId": "socpa-accounting-framework-r001",
      "paragraphReference": "SOCPA-AF-1",
      "ruleText": "Entities in Saudi Arabia shall apply SOCPA-approved accounting standards including IFRS adoption requirements as mandated for their entity category.",
