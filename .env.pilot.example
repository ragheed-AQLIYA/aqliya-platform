# LocalContentOS L5 pilot — environment template (no real secrets)
#
# You do NOT need a separate pilot .env file if you use:
#   npm run dev:localcontent-pilot
# That script reads .env (or .env.local), swaps only the database name to
# aqliya_lc_pilot for the dev process, and sets LOCALCONTENT_CONTENT_BACKEND=prisma.
#
# Use this file as a checklist when provisioning a dedicated pilot host or CI secret store.
# Copy values into deployment secrets or local .env — never commit real passwords.

# === Required (shared with main dev .env) ===
# Host/user/password come from your existing .env; pilot runtime swaps dbname only.
DATABASE_URL="postgresql://postgres:change-me@localhost:5432/aqliya_lc_pilot?schema=public"

# NextAuth — pilot dev binds to port 3001 by default
AUTH_SECRET=change-me-use-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# === LocalContentOS pilot (required on pilot processes) ===
LOCALCONTENT_CONTENT_BACKEND=prisma

# === Recommended ===
DOWNLOAD_TOKEN_SECRET=change-me-use-openssl-rand-base64-32
LOCAL_STORAGE_DIR=./uploads
STORAGE_PROVIDER=local
LOG_LEVEL=debug

# === Optional ===
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
AI_CLOUD_API_KEY=
AI_CLOUD_BASE_URL=
AI_CLOUD_MODEL=
