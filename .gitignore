# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/cypress/videos/
/cypress/screenshots/

# next.js
/.next/
/out/

# production
/backups/
/uploads/
/build

# misc
.DS_Store
*.pem
.opencode/
/lighthouse-reports/
.playwright-mcp/
.tmp.*

# local runtime / tool artifacts (Category B8 — project-organization 2026-06-01)
.data/
.understand-anything/
tmp-*.md
tmp-*.txt
tmp_write_*.py
gen_v02_test.py

# temp scripts (agent one-offs and scratch)
scripts/_*
scripts/_tmp-*

# drafts and collateral (not source of truth)
docs/config-drafts/
docs/commercial-pack/
docs/demo/

# report evidence (prevents future contamination; already-tracked reports still visible)
docs/reports/
!docs/reports/project-organization/
!docs/reports/project-organization/**

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev*.log

# test artifacts
/test-results/

# env files — ignore sensitive/private envs, keep templates committable
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Local cleanup quarantine
.local-cleanup/

# Windows desktop.ini files (generated by File Explorer)
desktop.ini

# Temporary test/debug files
temp_*
*.tmp.sql
*.tmp.mjs
*.tmp.js

# Local live test results
l1-live-results.txt
