# === Required ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aqliya

# NextAuth v5 — AUTH_SECRET is required at runtime (auth-config + middleware).
# NEXTAUTH_SECRET is accepted as a legacy alias by validate-env.mjs only.
AUTH_SECRET=change-me-use-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# === Recommended for controlled deployment ===
# Optional for startup; session-authenticated evidence downloads work without it.
# Required when using signed/token-based evidence download URLs.
DOWNLOAD_TOKEN_SECRET=change-me-use-openssl-rand-base64-32
LOCAL_STORAGE_DIR=./uploads
STORAGE_PROVIDER=local
# === AQLIYA Platform ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Analytics ===
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# === Error Monitoring ===
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# === AI (assistive features only — optional) ===
AI_CLOUD_API_KEY=
AI_CLOUD_BASE_URL=
AI_CLOUD_MODEL=
AI_CLOUD_PROVIDER_NAME=

# === File scanning (optional — not yet integrated) ===
SCANNER_PROVIDER=

# === Performance ===
ANALYZE=false

# === Logging ===
LOG_LEVEL=debug
