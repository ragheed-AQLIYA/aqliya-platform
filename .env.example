# === Required ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aqliya
# pgvector Docker (avoids local Postgres on 5432): docker compose -f docker-compose.yml -f docker-compose.pgvector.yml up -d db
# DATABASE_URL_PGVECTOR_DOCKER=postgresql://postgres:postgres@localhost:5434/aqliya_pilot

# NextAuth v5 — AUTH_SECRET is required at runtime (auth-config + middleware).
# NEXTAUTH_SECRET is accepted as a legacy alias by validate-env.mjs only.
AUTH_SECRET=change-me-use-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# === Recommended for controlled deployment ===
# Optional for startup; session-authenticated evidence downloads work without it.
# Required when using signed/token-based evidence download URLs.
DOWNLOAD_TOKEN_SECRET=change-me-use-openssl-rand-base64-32
LOCAL_STORAGE_DIR=./uploads
STORAGE_PROVIDER=local
# === AQLIYA Platform ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Marketing launch (optional) ===
# Cal.com / Calendly link for Schedule Diagnostic CTAs
NEXT_PUBLIC_BOOKING_URL=
# YouTube/Vimeo embed for /demo executive video section
NEXT_PUBLIC_DEMO_VIDEO_URL=

# === Analytics ===
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# === Error Monitoring ===
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# === AI (assistive features only — optional) ===
# cloud | local | hybrid — hybrid routes mapping tasks to local Ollama when FF_AI_REAL_PROVIDERS=true
AI_MODE=cloud
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_CLOUD_API_KEY=
AI_CLOUD_BASE_URL=
AI_CLOUD_MODEL=
AI_CLOUD_PROVIDER_NAME=
AI_LOCAL_BASE_URL=http://localhost:11434
# e.g. llama3, qwen3:8b (must match `ollama list` tag)
AI_LOCAL_MODEL=llama3
AI_LOCAL_EMBED_MODEL=nomic-embed-text
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=default
EMBEDDING_PROVIDER=mock
FF_AI_REAL_PROVIDERS=false
FF_AI_RAG=false
FF_AUDIT_INTELLIGENCE=false
FF_AUDIT_REPORTING_GRAPH=false
FF_AUDIT_LEAD_SCHEDULE_AUTO=false
FF_AUDIT_RECONCILIATION=false
FF_AUDIT_RECONCILIATION_GATES=false
FF_AUDIT_FS_V2=false
FF_AUDIT_IFRS_RULES=false
FF_AUDIT_SOCPA_RULES=false
FF_AUDIT_DISCLOSURE_AUTO=false
FF_AUDIT_APPROVAL_GATES=false
FF_AUDIT_MIND_MAP=false

# === File scanning (production uploads require SCANNER_PROVIDER) ===
# Supported: clamav
SCANNER_PROVIDER=
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# === Redis (optional — falls back to in-memory) ===
REDIS_URL=redis://localhost:6379

# === Rate Limiter (memory | redis) ===
# IMPORTANT: Set RATE_LIMITER=redis in multi-instance deployments (ECS Fargate, Kubernetes).
# memory = per-process only, limits are not shared across tasks (unsafe at scale).
# redis  = shared across all tasks, requires REDIS_URL.
RATE_LIMITER=memory

# === Performance ===
ANALYZE=false

# === Logging ===
LOG_LEVEL=debug

# ===== OAuth (L0-05 partial — invite-only, optional) =====
# User must already exist in DB (seed/signup). Does not auto-provision.
# SAML/LDAP/SCIM enterprise packages are not implemented.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_AZURE_AD_ID=
# AUTH_AZURE_AD_TENANT_ID=
# AUTH_AZURE_AD_SECRET=
# AUTH_OKTA_ID=
# AUTH_OKTA_SECRET=
# AUTH_OKTA_ISSUER=
# SCIM_API_KEY=           # Bearer token for /api/scim/v2/*
# SCIM_DEFAULT_ORG_ID=    # Target org for SCIM provisioning (required when SCIM enabled)

# === Notification Engine ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aqliya.ai
SMTP_SECURE=false
NOTIFICATION_RATE_LIMIT_PER_MIN=60

# ===== FUTURE: CRM Connection Secrets (S7-03 — roadmap, not yet implemented) =====
# Per-connection secrets stored in vault. CRM sync is types+interface only.
# # CRM_CONNECTION__<id>__ACCESS_TOKEN=

# ===== FUTURE: ERP Integration Secrets (LC-08 — roadmap, not yet implemented) =====
# Per-connection secrets stored in vault. ERP integration is types+interface only.
# # ERP_CONNECTION__<id>__API_KEY=

# === Intelligence Core — Tier 2 feature flags (off by default) ===
# FF_ABAC_SHADOW=false          # disable ABAC shadow logging (default: on)
# FF_ABAC_ENFORCE=true          # block access when ABAC denies (pilot orgs only)
# ABAC_ENFORCE_ORG_IDS=          # comma-separated org IDs for enforce pilot
# FF_EVENT_OUTBOX=true          # transactional outbox on platform audit writes
# FF_EVENT_SCHEMA_REGISTRY=true # validate event envelopes at outbox insert/dispatch
# FF_AUDIT_ISA_RULES=true       # ISA rules runtime after FS rebuild