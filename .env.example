# === Required ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aqliya
# pgvector Docker (avoids local Postgres on 5432): docker compose -f docker-compose.yml -f docker-compose.pgvector.yml up -d db
# DATABASE_URL_PGVECTOR_DOCKER=postgresql://postgres:postgres@localhost:5434/aqliya_pilot

# NextAuth v5 — AUTH_SECRET is required at runtime (auth-config + middleware).
# NEXTAUTH_SECRET is accepted as a legacy alias by validate-env.mjs only.
AUTH_SECRET=change-me-use-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# === Recommended for controlled deployment ===
# Optional for startup; session-authenticated evidence downloads work without it.
# Required when using signed/token-based evidence download URLs.
DOWNLOAD_TOKEN_SECRET=change-me-use-openssl-rand-base64-32
LOCAL_STORAGE_DIR=./uploads
STORAGE_PROVIDER=local
# === AQLIYA Platform ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Marketing launch (optional) ===
# Cal.com / Calendly link for Schedule Diagnostic CTAs
NEXT_PUBLIC_BOOKING_URL=
# YouTube/Vimeo embed for /demo executive video section
NEXT_PUBLIC_DEMO_VIDEO_URL=

# === Analytics ===
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# === Error Monitoring ===
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# === AI (assistive features only — optional) ===
AI_CLOUD_API_KEY=
AI_CLOUD_BASE_URL=
AI_CLOUD_MODEL=
AI_CLOUD_PROVIDER_NAME=

# === File scanning (optional — not yet integrated) ===
SCANNER_PROVIDER=

# === Redis (optional — falls back to in-memory) ===
REDIS_URL=redis://localhost:6379

# === Rate Limiter (memory | redis) ===
RATE_LIMITER=memory

# === Performance ===
ANALYZE=false

# === Logging ===
LOG_LEVEL=debug

# ===== OAuth (L0-05 partial — invite-only, optional) =====
# User must already exist in DB (seed/signup). Does not auto-provision.
# SAML/LDAP/SCIM enterprise packages are not implemented.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_AZURE_AD_ID=
# AUTH_AZURE_AD_TENANT_ID=
# AUTH_AZURE_AD_SECRET=
# AUTH_OKTA_ID=
# AUTH_OKTA_SECRET=
# AUTH_OKTA_ISSUER=
# SCIM_API_KEY=           # Bearer token for /api/scim/v2/*
# SCIM_DEFAULT_ORG_ID=    # Target org for SCIM provisioning (required when SCIM enabled)

# === Notification Engine ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aqliya.ai
SMTP_SECURE=false
NOTIFICATION_RATE_LIMIT_PER_MIN=60

# ===== FUTURE: CRM Connection Secrets (S7-03 — roadmap, not yet implemented) =====
# Per-connection secrets stored in vault. CRM sync is types+interface only.
# # CRM_CONNECTION__<id>__ACCESS_TOKEN=

# ===== FUTURE: ERP Integration Secrets (LC-08 — roadmap, not yet implemented) =====
# Per-connection secrets stored in vault. ERP integration is types+interface only.
# # ERP_CONNECTION__<id>__API_KEY=