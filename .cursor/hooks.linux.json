{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "bash .cursor/hooks/block-heavy-commands.sh",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "bash .cursor/hooks/after-edit-light-check.sh",
        "timeout": 20
      },
      {
        "command": "bash .cursor/hooks/protect-env-files.sh",
        "timeout": 10
      }
    ]
  }
}
